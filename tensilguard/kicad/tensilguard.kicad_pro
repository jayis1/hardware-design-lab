(kicad_pro (version 20221206)
  (generator "tensilguard")
  (general
    (thickness 1.6)
    (legacy_teardrops no))
  (paper "A4")
  (title_block
    (title "TensilGuard — Magnetoelastic Cable Tension & Structural Health Monitor")
    (date "2026-07-02")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Surface electronics — MCU, radio, mag front-end, AE, power")
    (comment 2 "MIT License — Author: jayis1"))
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "Internal 1")
    (2 "In2.Cu" signal "Internal 2")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user))
  (setup
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x0001000ffffffff)
      (plot_on_all_layers_selection 0x0000000)
      (disableapertmacroscale no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (svgprecision 4)
      (plotframeref no)
      (mode 1)
      (useauxorigin no)
      (pseudoplacement no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits no)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisiptext no)
      (padsonsilk no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "gerbers/")))
  (net_settings
    (classes
      (default "default" (copperpour_over_rim yes) (via_setup 0.2 0.4))
      ("Power" "Power" (copperpour_over_rim yes) (via_setup 0.3 0.6))))
  (board_setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 0.2) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "prepreg") (thickness 0.2) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "core") (thickness 0.2) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.035))))
  (securities
    (copyright "© 2026 jayis1 — MIT License")))