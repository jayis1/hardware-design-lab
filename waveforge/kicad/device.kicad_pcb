(kicad_pcb (version 20230621)
  (generator "pcbnew")
  (general
    (thickness 1.6)
  )
  (paper "A4")
  (title_block
    (title "WaveForge — Polyphonic Digital Audio Synthesizer Engine")
    (date "2026-06-15")
    (rev "1.0")
    (company "WaveForge Open Hardware")
  )

  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "Dielectric1" (type "prepreg") (thickness 0.15) (material "FR-4") (epsilon_r 4.2) (loss_tangent 0.02))
      (layer "In1.Cu" (type "copper") (thickness 0.0175))
      (layer "Dielectric2" (type "core") (thickness 1.2) (material "FR-4") (epsilon_r 4.5) (loss_tangent 0.02))
      (layer "In2.Cu" (type "copper") (thickness 0.0175))
      (layer "Dielectric3" (type "prepreg") (thickness 0.15) (material "FR-4") (epsilon_r 4.2) (loss_tangent 0.02))
      (layer "B.Cu" (type "copper") (thickness 0.035))
    )

    (pad_size 1.5 1.5)
    (pad_drill 0.8)
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.1)
    (grid_origin 0 0)
    (grid_spacing 0.5 0.5)

    (defaults
      (edge_clearance 0.5)
      (courtyard_clearance 0.25)
    )
  )

  ; ============================================================
  ; NET CLASSES
  ; ============================================================

  (net_class "Default" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.4)
    (uvia_drill 0.2)
  )

  (net_class "Power"
    (clearance 0.2)
    (trace_width 0.3)
    (via_dia 0.6)
    (via_drill 0.3)
  )

  (net_class "GND"
    (clearance 0.2)
    (trace_width 0.3)
    (via_dia 0.6)
    (via_drill 0.3)
  )

  (net_class "USB_Diff"
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (diff_pair_gap 0.15)
    (diff_pair_width 0.2)
  )

  (net_class "Audio"
    (clearance 0.2)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
  )

  (net_class "HighSpeed"
    (clearance 0.2)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
  )

  ; ============================================================
  ; BOARD OUTLINE (100 mm × 80 mm)
  ; ============================================================

  (gr_rect (start 0 0) (end 100 80) (layer "Edge.Cuts") (width 0.15) (uuid edge0001))

  ; Corner rounding — 2 mm radius arcs at each corner
  (gr_arc (start 2 0) (mid 0 0) (end 0 2) (layer "Edge.Cuts") (width 0.15) (uuid edge0002))
  (gr_arc (start 98 0) (mid 100 0) (end 100 2) (layer "Edge.Cuts") (width 0.15) (uuid edge0003))
  (gr_arc (start 100 78) (mid 100 80) (end 98 80) (layer "Edge.Cuts") (width 0.15) (uuid edge0004))
  (gr_arc (start 0 78) (mid 0 80) (end 2 80) (layer "Edge.Cuts") (width 0.15) (uuid edge0005))

  ; ============================================================
  ; MOUNTING HOLES (4× M3 at 5 mm from edges)
  ; ============================================================

  (module "MountingHole:MountingHole_3.2mm_M3" (at 5 5) (uuid mh0001))
  (module "MountingHole:MountingHole_3.2mm_M3" (at 95 5) (uuid mh0002))
  (module "MountingHole:MountingHole_3.2mm_M3" (at 95 75) (uuid mh0003))
  (module "MountingHole:MountingHole_3.2mm_M3" (at 5 75) (uuid mh0004))

  ; ============================================================
  ; KEEPOUT ZONES
  ; ============================================================

  ; Analog keepout — no digital traces near codec
  (zone (net "") (net_name "") (layer "F.Cu") (uuid kz0001)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 240 65) (xy 310 65) (xy 310 125) (xy 240 125)
      )
    )
  )

  ; Crystal keepout — no traces within 1 mm of crystals
  (zone (net "") (net_name "") (layer "F.Cu") (uuid kz0002)
    (hatch edge 0.5)
    (connect_pads no)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 135 58) (xy 150 58) (xy 150 68) (xy 135 68)
      )
    )
  )

  ; ============================================================
  ; COPPER ZONES (Fills)
  ; ============================================================

  ; Top copper ground fill (with analog island gap)
  (zone (net "GND") (net_name "GND") (layer "F.Cu") (uuid zone0001)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 0.5 0.5) (xy 99.5 0.5) (xy 99.5 79.5) (xy 0.5 79.5)
      )
    )
  )

  ; Inner Layer 2 — continuous GND plane
  (zone (net "GND") (net_name "GND") (layer "In1.Cu") (uuid zone0002)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 0.5 0.5) (xy 99.5 0.5) (xy 99.5 79.5) (xy 0.5 79.5)
      )
    )
  )

  ; Inner Layer 3 — split power plane (3.3V and 1.2V)
  (zone (net "VDD_3V3") (net_name "VDD_3V3") (layer "In2.Cu") (uuid zone0003)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 0.5 0.5) (xy 70 0.5) (xy 70 79.5) (xy 0.5 79.5)
      )
    )
  )

  (zone (net "VDD_CORE") (net_name "VDD_CORE") (layer "In2.Cu") (uuid zone0004)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 70 0.5) (xy 99.5 0.5) (xy 99.5 79.5) (xy 70 79.5)
      )
    )
  )

  ; Bottom ground fill
  (zone (net "GND") (net_name "GND") (layer "B.Cu") (uuid zone0005)
    (hatch edge 0.5)
    (connect_pads yes)
    (min_thickness 0.25)
    (fill solid)
    (polygon
      (pts
        (xy 0.5 0.5) (xy 99.5 0.5) (xy 99.5 79.5) (xy 0.5 79.5)
      )
    )
  )

