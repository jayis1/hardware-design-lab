    (at 45 30)
    (attr smd)
    (property "Reference" "U1" (at 0 -5.5) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "STM32H733VIH6" (at 0 5.5) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (property "Footprint" "" (at 0 0) (layer "F.Fab") (effects (font (size 1.27 1.27) (thickness 0.15))))
