  ; Board outline: 90 × 60 mm rounded rectangle
  (gr_line (start 0 0) (end 90 0) (layer "Edge.Cuts") (width 0.2))
  (gr_line (start 90 0) (end 90 60) (layer "Edge.Cuts") (width 0.2))
  (gr_line (start 90 60) (end 0 60) (layer "Edge.Cuts") (width 0.2))
