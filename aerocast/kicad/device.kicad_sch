  (wire (pts (xy 180 75) (xy 190 75))   (net 13))  ; PB8 SCL
  (wire (pts (xy 290 175)(xy 295 175))  (net 14))  ; I2C4_SDA
  (wire (pts (xy 180 70) (xy 190 70))   (net 14))  ; PB9 SDA

