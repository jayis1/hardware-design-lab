  )

  ;; =========================================================
  ;; Representative copper traces
  ;; =========================================================
  (segment (start 60 40) (end 90 40) (width 0.15) (layer "F.Cu") (net 7))
  (segment (start 90 40) (end 90 42) (width 0.15) (layer "F.Cu") (net 7))
  (segment (start 60 40) (end 30 30) (width 0.15) (layer "F.Cu") (net 9))
  (segment (start 30 30) (end 30 31.75) (width 0.15) (layer "F.Cu") (net 9))
  (segment (start 60 40) (end 105 25) (width 0.15) (layer "F.Cu") (net 11))
  (segment (start 60 40) (end 105 40) (width 0.15) (layer "F.Cu") (net 13))
  (via (at 60 40) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 90 40) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 30 30) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))

  ;; Ground pour hint (In1.Cu is solid GND plane)
  (zone (layer "In1.Cu") (net 3)
    (connect_pads (clearance 0.2))
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 0 0) (xy 120 0) (xy 120 80) (xy 0 80)))
  )

  (instances (project "aerocast" (path "/aerocast-pcb-0001")))
