  ;; J1 — USB-C at (10, 70)
  (footprint "Connector_USB:USB_C_Receptacle_HRO_TYPE-C-31-M-12"
    (layer "F.Cu")
    (tstamp j1-usbc)
    (at 10 70)
    (attr smd)
    (property "Reference" "J1" (at 0 -5))
    (property "Value"  "USB-C" (at 0 5))
    (property "Author" "jayis1")
    (pad "A4" smd rect (size 0.3 1.0) (at -3.2 -2.5) (layers "F.Cu" "F.Mask") (net 1))
    (pad "A1" smd rect (size 0.3 1.0) (at -4.0 -2.5) (layers "F.Cu" "F.Mask") (net 3))
    (pad "B9" smd rect (size 0.3 1.0) (at  3.2 -2.5) (layers "F.Cu" "F.Mask") (net 3))
    (pad "B4" smd rect (size 0.3 1.0) (at  4.0 -2.5) (layers "F.Cu" "F.Mask") (net 1))
