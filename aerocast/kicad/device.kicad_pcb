    (pad "2" smd rect (size 0.4 0.3) (at -0.3 -0.6) (layers "F.Cu" "F.Mask") (net 11))
    (pad "3" smd rect (size 0.4 0.3) (at  0.3 -0.6) (layers "F.Cu" "F.Mask") (net 12))
    (pad "5" smd rect (size 0.4 0.3) (at  0.9 -0.6) (layers "F.Cu" "F.Mask") (net 3))
