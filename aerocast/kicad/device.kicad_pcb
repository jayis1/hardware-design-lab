  ;; J4 — RS-485 header at (110, 70)
  (footprint "Connector_JST:JST_PH_B4B-PH-K_1x04_P2.00mm_Vertical"
    (layer "F.Cu")
    (tstamp j4-wind)
    (at 110 70)
    (attr through_hole)
    (property "Reference" "J4" (at 0 -3))
    (property "Value"  "Anemometer_RS485" (at 0 3))
    (property "Author" "jayis1")
    (pad "1" thru_hole circle (size 0.8 0.8) (drill 0.6) (at -3 0) (layers "*.Cu" "*.Mask") (net 24))
    (pad "2" thru_hole circle (size 0.8 0.8) (drill 0.6) (at -1 0) (layers "*.Cu" "*.Mask") (net 25))
    (pad "3" thru_hole circle (size 0.8 0.8) (drill 0.6) (at  1 0) (layers "*.Cu" "*.Mask") (net 1))
    (pad "4" thru_hole circle (size 0.8 0.8) (drill 0.6) (at  3 0) (layers "*.Cu" "*.Mask") (net 3))
  )

  ;; D1 — 650 nm laser TO-18 at (60, 60)
  (footprint "OptoDevice:TO-18_3Pin"
    (layer "F.Cu")
    (tstamp d1-laser)
    (at 60 60)
    (attr through_hole)
    (property "Reference" "D1" (at 0 -3))
    (property "Value"  "650nm_50mW" (at 0 3))
    (property "Author" "jayis1")
    (pad "1" thru_hole circle (size 1.5 1.5) (drill 0.8) (at 0 0) (layers "*.Cu" "*.Mask") (net 1))
    (pad "2" thru_hole circle (size 1.5 1.5) (drill 0.8) (at 1.27 0) (layers "*.Cu" "*.Mask") (net 3))
