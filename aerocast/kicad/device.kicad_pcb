    (pad "4" smd rect (size 0.5 0.3) (at -0.4  0.25) (layers "F.Cu" "F.Mask") (net 3))
  )

  ;; U5 — BMP390 LGA-10 at (105, 32)
  (footprint "Package_LGA:Bosch_LGA-10_2.5x2.5mm_P0.6mm"
    (layer "F.Cu")
    (tstamp u5-bmp)
    (at 105 32)
    (attr smd)
    (property "Reference" "U5" (at 0 -2.5))
    (property "Value"  "BMP390" (at 0 2.5))
