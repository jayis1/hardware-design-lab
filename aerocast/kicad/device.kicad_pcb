    (tstamp d2-uv)
    (at 70 60)
    (attr smd)
    (property "Reference" "D2" (at 0 -2))
    (property "Value"  "340nm_300mW" (at 0 2))
    (property "Author" "jayis1")
    (pad "1" smd rect (size 1.2 1.0) (at -1.5 0) (layers "F.Cu" "F.Mask") (net 21))
    (pad "2" smd rect (size 1.2 1.0) (at  1.5 0) (layers "F.Cu" "F.Mask") (net 3))
