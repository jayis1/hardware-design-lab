    (pad "2" smd rect (size 0.6 0.8) (at -2 -1.75)(layers "F.Cu" "F.Mask") (net 13))
    (pad "3" smd rect (size 0.6 0.8) (at -2 -0.5) (layers "F.Cu" "F.Mask") (net 14))
    (pad "4" smd rect (size 0.6 0.8) (at -2  0.75)(layers "F.Cu" "F.Mask") (net 3))
