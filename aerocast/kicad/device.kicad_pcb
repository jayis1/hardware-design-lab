    (pad "4" smd rect (size 0.5 1.5) (at -3 0) (layers "F.Cu" "F.Mask") (net 16))
    (pad "5" smd rect (size 0.5 1.5) (at -2 0) (layers "F.Cu" "F.Mask") (net 17))
