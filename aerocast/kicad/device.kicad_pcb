  ;; U6 — SDP810 DFN-8 at (105, 40)
  (footprint "Sensor:Sensirion_SDP8xx_DFN-8_5x8mm_P1.25mm"
    (layer "F.Cu")
    (tstamp u6-sdp)
    (at 105 40)
    (attr smd)
    (property "Reference" "U6" (at 0 -5))
    (property "Value"  "SDP810-500Pa" (at 0 5))
