(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (stackup
      (layer "F.SilkS" (type "Top Silk Screen"))
      (layer "F.Paste" (type "Top Solder Paste"))
      (layer "F.Mask" (type "Top Solder Mask") (thickness 0.01))
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 0.2) (material "FR4") (epsilon_r 4.4))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "prepreg") (thickness 0.7) (material "FR4") (epsilon_r 4.4))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "core") (thickness 0.2) (material "FR4") (epsilon_r 4.4))
      (layer "B.Cu" (type "copper") (thickness 0.035))
      (layer "B.Mask" (type "Bottom Solder Mask") (thickness 0.01))
      (layer "B.Paste" (type "Bottom Solder Paste"))
      (layer "B.SilkS" (type "Bottom Silk Screen"))
      (copper_finish "ENIG")
      (dielectric_constraints no)
    )
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (outputdirectory "gerbers/")
    )
  )

  (net 0 "")
  (net 1 "+3V3")
  (net 2 "GND")
  (net 3 "VBUS")
  (net 4 "VBAT")
  (net 5 "VIN")
  (net 6 "VDDA")
  (net 7 "AVDD_ISO")
  (net 8 "AGND_ISO")
  (net 9 "SPI2_SCK")
  (net 10 "SPI2_MISO")
  (net 11 "SPI2_MOSI")
  (net 12 "SPI3_SCK")
  (net 13 "SPI3_MISO")
  (net 14 "SPI3_MOSI")
  (net 15 "I2C1_SCL")
  (net 16 "I2C1_SDA")
  (net 17 "BLE_TX")
  (net 18 "BLE_RX")
  (net 19 "LORA_TX")
  (net 20 "LORA_RX")
  (net 21 "LORA_DIO1")
  (net 22 "LORA_NSS")
  (net 23 "LORA_RESET")
  (net 24 "ADC_DRDY")
  (net 25 "ADC_CS")
  (net 26 "ADC_RESET")
  (net 27 "DISP_CS")
  (net 28 "DISP_DC")
  (net 29 "DISP_RST")
  (net 30 "USB_DM")
  (net 31 "USB_DP")
  (net 32 "V1_ISO")
  (net 33 "V2_ISO")
  (net 34 "V3_ISO")
  (net 35 "I1_IN")
  (net 36 "I2_IN")
  (net 37 "I3_IN")
  (net 38 "IN_IN")
  (net 39 "QSPI_CS")
  (net 40 "QSPI_CLK")
  (net 41 "QSPI_IO0")
  (net 42 "QSPI_IO1")
  (net 43 "SD_CS")
  (net 44 "LED_RED")
  (net 45 "LED_GREEN")
  (net 46 "CHARGE_EN")
  (net 47 "CHARGE_STAT")
  (net 48 "TOUCH_IRQ")
  (net 49 "ADC_PWDN")
  (net 50 "MAIN_PWR_EN")

  ; ==========================================================================
  ; Board outline: 120 × 72 mm, origin at (0,0)
  ; ==========================================================================
  (gr_line (start 0 0) (end 120 0) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 120 0) (end 120 72) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 120 72) (end 0 72) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 0 72) (end 0 0) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))

  ; Mounting holes (M3, 4 corners with 3mm offset)
  (gr_circle (start 3 3) (end 5 3) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_circle (start 117 3) (end 119 3) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_circle (start 3 69) (end 5 69) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))
  (gr_circle (start 117 69) (end 119 69) (stroke (width 0.15) (type solid)) (layer "Edge.Cuts"))

  ; Silk screen text
  (gr_text "WattLens v1.0" (at 60 5 0) (layer "F.SilkS") (effects (font (size 2 2) bold)))
  (gr_text "Author: jayis1" (at 60 9 0) (layer "F.SilkS") (effects (font (size 1.5 1.5))))
  (gr_text "MIT License (c) 2026 jayis1" (at 60 12 0) (layer "F.SilkS") (effects (font (size 1 1))))
  (gr_text "600V CAT III — Isolated" (at 15 68 0) (layer "F.SilkS") (effects (font (size 1.2 1.2) bold)))
  (gr_text "4-Layer FR4 1.6mm" (at 95 68 0) (layer "F.SilkS") (effects (font (size 1 1))))

  ; Isolation barrier line (2.5mm slot between mains and SELV domains)
  (gr_line (start 45 15) (end 45 60) (stroke (width 0.5) (type solid)) (layer "F.SilkS"))
  (gr_text "ISOLATION BARRIER" (at 45 13 90) (layer "F.SilkS") (effects (font (size 0.8 0.8))))

  ; ==========================================================================
  ; Footprints
  ; ==========================================================================

