  ; ========================================================================
  ; Vias (GND stitching)
  ; ========================================================================

  (via (at 5 5) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 5 37) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 67 5) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 67 37) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 36 20) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 30 25) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 42 25) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 36 15) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 36 25) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))

  ; ========================================================================
  ; Zones (GND pour)
  ; ========================================================================

  (zone (net 2) (net_name "GND") (layer "B.Cu") (tstamp 0)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 0 0) (xy 72 0) (xy 72 42) (xy 0 42))
    )
  )

  (zone (net 2) (net_name "GND") (layer "In1.Cu") (tstamp 1)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 0 0) (xy 72 0) (xy 72 42) (xy 0 42))
    )
  )

  (zone (net 1) (net_name "VCC") (layer "In2.Cu") (tstamp 2)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.2) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy 1 1) (xy 71 1) (xy 71 41) (xy 1 41))
    )
  )

  ; ========================================================================
  ; Design rules
  ; ========================================================================

  (rule "min_track_width"
    (condition "A.NetClass == 'Default'")
    (constraint track_width (min 0.15)))
  (rule "min_clearance"
    (condition "A.NetClass == 'Default'")
    (constraint clearance (min 0.15)))
)