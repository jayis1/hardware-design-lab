(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 0.8)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal "Top")
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal "Bottom")
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (stackup
      (layer "F.Cu" (type copper) (thickness 0.018))
      (layer "dielectric 1" (type core) (thickness 0.075) (material "FR4"))
      (layer "In1.Cu" (type copper) (thickness 0.018))
      (layer "dielectric 2" (type prepreg) (thickness 0.075) (material "FR4"))
      (layer "In2.Cu" (type copper) (thickness 0.018))
      (layer "dielectric 3" (type core) (thickness 0.075) (material "FR4"))
      (layer "B.Cu" (type copper) (thickness 0.018))
      (copper_finish "ENIG")
      (dielectric_constraints no)
    )
    (pad_to_mask_clearance 0.05)
    (aux_axis_origin 0 0)
    (grid_origin 0 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output yes)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "VBAT")
  (net 4 "VUSB")
  (net 5 "VSENS")
  (net 6 "I2C1_SCL")
  (net 7 "I2C1_SDA")
  (net 8 "SPI1_SCK")
  (net 9 "SPI1_MISO")
  (net 10 "SPI1_MOSI")
  (net 11 "SPI2_SCK")
  (net 12 "SPI2_MOSI")
  (net 13 "SPI4_SCK")
  (net 14 "SPI4_MISO")
  (net 15 "SPI4_MOSI")
  (net 16 "USART2_TX")
  (net 17 "USART2_RX")
  (net 18 "USART3_TX")
  (net 19 "USART3_RX")
  (net 20 "ADC_H2")
  (net 21 "ADC_BAT")
  (net 22 "NRST")
  (net 23 "BOOT0")
  (net 24 "SD_CS")
  (net 25 "DISP_CS")
  (net 26 "DISP_DC")
  (net 27 "DISP_RST")
  (net 28 "FLASH_CS")
  (net 29 "BLE_RST")
  (net 30 "CHRG_STAT")
  (net 31 "SENS_PWR")
  (net 32 "PUMP_CTL")
  (net 33 "STATUS_LED")
  (net 34 "SAMPLE_LED")
  (net 35 "USB_DM")
  (net 36 "USB_DP")
  (net 37 "HSE_IN")
  (net 38 "HSE_OUT")
  (net 39 "BTN_ANALYZE")
  (net 40 "BTN_POWER")
  (net 41 "unconnected-(U1-Pad34)")

  ; ========================================================================
  ; Board Outline — 72 × 42 mm
  ; ========================================================================

  (gr_line (start 0 0) (end 72 0)
    (stroke (width 0.1) (type default))
    (layer "Edge.Cuts"))
  (gr_line (start 72 0) (end 72 42)
    (stroke (width 0.1) (type default))
    (layer "Edge.Cuts"))
  (gr_line (start 72 42) (end 0 42)
    (stroke (width 0.1) (type default))
    (layer "Edge.Cuts"))
  (gr_line (start 0 42) (end 0 0)
    (stroke (width 0.1) (type default))
    (layer "Edge.Cuts"))

  ; ========================================================================
  ; Silkscreen Text
  ; ========================================================================

  (gr_text "BreathPrint v1.0"
    (at 36 39 0)
    (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.15)))
  )
  (gr_text "Author: jayis1"
    (at 36 37 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "MIT License (c) 2026"
    (at 36 35.5 0)
    (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.08)))
  )
  (gr_text "Sensor Array"
    (at 10 5 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "MCU"
    (at 36 20 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "BLE"
    (at 62 30 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "USB-C"
    (at 65 8 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "OLED"
    (at 36 33 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )
  (gr_text "BATT"
    (at 60 38 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.1)))
  )

  ; ========================================================================
  ; Footprints
  ; ========================================================================

