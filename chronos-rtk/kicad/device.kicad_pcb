  )

  ;; Crystal Y1 (32.768 kHz)
  (module "Crystal:Crystal_SMD_3215-2Pin_3.2x1.5mm" (at 28 28) (layer "F.Cu")
    (fp_text reference "Y1" (at 0 -2))
  )

  ;; TCXO Y3 (32 MHz for SX1262)
  (module "Oscillator:Oscillator_SMD_TXC_7.0x5.0mm" (at 58 28) (layer "F.Cu")
