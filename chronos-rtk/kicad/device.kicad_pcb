  ;; ========================================

  ;; ZED-F9P thermal vias (9 vias under center pad)
  (via (at 13 30) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 14 30) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 15 30) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 13 31) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 14 31) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 15 31) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 13 32) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 14 32) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 15 32) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))

  ;; TPS62A02 thermal vias (4 vias)
  (via (at 14.5 7.5) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 15.5 7.5) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 14.5 8.5) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 15.5 8.5) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))

  ;; SX1262 thermal vias (6 vias)
  (via (at 54 34) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 55 34) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 56 34) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 54 36) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 55 36) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))
  (via (at 56 36) (size 0.6) (drill 0.3) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu") (net "GND"))

  ;; ========================================
  ;; GROUND PLANE ZONES
  ;; ========================================

  (zone (net "GND") (layer "In1.Cu") (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 0 0) (xy 70 0) (xy 70 45) (xy 0 45)))
  )

  (zone (net "GND") (layer "In4.Cu") (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 0 0) (xy 70 0) (xy 70 45) (xy 0 45)))
  )

  (zone (net "VDD_3V3") (layer "In2.Cu") (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts (xy 10 5) (xy 60 5) (xy 60 40) (xy 10 40)))
  )

