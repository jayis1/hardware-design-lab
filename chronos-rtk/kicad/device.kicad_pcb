  )

  ;; Buttons SW1-3
  (module "Button_Switch_SMD:SW_Push_1P1T_6x6mm" (at 20 12) (layer "F.Cu")
    (fp_text reference "SW1" (at 0 -2))
  )
  (module "Button_Switch_SMD:SW_Push_1P1T_6x6mm" (at 25 12) (layer "F.Cu")
    (fp_text reference "SW2" (at 0 -2))
  )
  (module "Button_Switch_SMD:SW_Push_1P1T_6x6mm" (at 30 12) (layer "F.Cu")
    (fp_text reference "SW3" (at 0 -2))
  )

  ;; LEDs
  (module "LED_SMD:LED_0603_1608Metric" (at 40 38) (layer "F.Cu")
    (fp_text reference "LED1" (at 0 -1.5))
  )
  (module "LED_SMD:LED_0603_1608Metric" (at 43 38) (layer "F.Cu")
    (fp_text reference "LED2" (at 0 -1.5))
  )
  (module "LED_SMD:LED_0603_1608Metric" (at 46 38) (layer "F.Cu")
    (fp_text reference "LED3" (at 0 -1.5))
  )

  ;; ========================================
  ;; DESIGN RULES
  ;; ========================================

  (design_rules
    (min_clearance 0.10)
    (min_track_width 0.10)
    (min_via_diameter 0.40)
    (min_via_drill 0.20)
    (min_microvia_diameter 0.25)
    (min_microvia_drill 0.10)
