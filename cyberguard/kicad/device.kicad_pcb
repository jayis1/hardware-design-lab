(kicad_pcb
  (version 20240101)
  (generator "hwi")
  (general
    (thickness 1.0)
  )
  (title_block
    (title "CyberGuard - Multi-Protocol Hardware Security Token")
    (date "2026-06-15")
    (rev "1.0")
    (company "Hardware Design Lab")
  )

  ;; ========================================
  ;; LAYER STACKUP
  ;; ========================================
  (stackup
    (layer "F.Cu" "copper" 0.035)
    (layer "Prepeg1" "dielectric" 0.1)
    (layer "In1.Cu" "copper" 0.0175)
    (layer "Core1" "dielectric" 0.2)
    (layer "In2.Cu" "copper" 0.0175)
    (layer "Prepeg2" "dielectric" 0.1)
    (layer "In3.Cu" "copper" 0.0175)
    (layer "Core2" "dielectric" 0.2)
    (layer "In4.Cu" "copper" 0.0175)
    (layer "Prepeg3" "dielectric" 0.1)
    (layer "B.Cu" "copper" 0.035)
  )

  ;; ========================================
  ;; BOARD OUTLINE (44mm x 20mm, 2mm corner radius)
  ;; ========================================
  (gr_rect (start 0 0) (end 44 20) (layer "Edge.Cuts") (width 0.1) (radius 2) (uuid "outline1"))
  
  ;; Keychain hole (4mm diameter, centered 3mm from bottom)
  (gr_circle (center 22 3) (end 24 3) (layer "Edge.Cuts") (width 0.1) (uuid "outline2"))

  ;; ========================================
  ;; KEEPOUT ZONES
  ;; ========================================
  ;; NFC antenna keepout (bottom layer, 30mm diameter circle)
  (keepout "" (polygon
    (pts (xy 22 14) (xy 37 14) (xy 37 -1) (xy 22 -1))
  ) (layer "F.Cu") (uuid "keepout1"))
  
  ;; BLE antenna keepout (5mm from top edge)
  (keepout "" (polygon
    (pts (xy 35 0) (xy 44 0) (xy 44 5) (xy 35 5))
  ) (layer "F.Cu") (uuid "keepout2"))

  ;; ========================================
  ;; NET CLASSES
  ;; ========================================
  (net_class "Default" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  (net_class "Power" ""
    (clearance 0.25)
    (trace_width 0.4)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  (net_class "USB" ""
    (clearance 0.2)
    (trace_width 0.1)
    (diff_pair_gap 0.127)
    (diff_pair_width 0.1)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  (net_class "SPI" ""
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
  )
  (net_class "RF" ""
    (clearance 0.3)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
  )

  ;; ========================================
  ;; COPPER ZONES
  ;; ========================================
  ;; Top ground pour (L1)
  (zone (net "GND") (net_name "GND") (layer "F.Cu") (uuid "zone1")
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (polygon (pts (xy 0 0) (xy 44 0) (xy 44 20) (xy 0 20)))
  )
  
  ;; Inner ground plane (L2)
  (zone (net "GND") (net_name "GND") (layer "In1.Cu") (uuid "zone2")
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (polygon (pts (xy 0 0) (xy 44 0) (xy 44 20) (xy 0 20)))
  )

  ;; Power plane (L3) - VDD_3V3 (80%) and VDD_1V8 (20%)
  (zone (net "VDD_3V3") (net_name "VDD_3V3") (layer "In2.Cu") (uuid "zone3")
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (polygon (pts (xy 0 0) (xy 44 0) (xy 44 16) (xy 0 16)))
  )
  
  (zone (net "VDD_1V8") (net_name "VDD_1V8") (layer "In2.Cu") (uuid "zone4")
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (polygon (pts (xy 0 16) (xy 44 16) (xy 44 20) (xy 0 20)))
  )

  ;; Bottom ground pour (L6)
  (zone (net "GND") (net_name "GND") (layer "B.Cu") (uuid "zone5")
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.15)
    (polygon (pts (xy 0 0) (xy 44 0) (xy 44 20) (xy 0 20)))
  )

  ;; ========================================
  ;; COMPONENT PLACEMENT (approximate coordinates)
  ;; ========================================
  ;; Origin: bottom-left corner of board
  ;; All coordinates in mm

  ;; J1 - USB-C connector (top-left, near board edge)
  (module "Connector_USB:USB_C_Receptacle_Amphenol_124018324606A" (at 3 10 0) (uuid "mod0001")
    (net "VBUS" "GND" "USB_DP" "USB_DM" "CC1" "CC2")
  )

  ;; D1 - ESD protection (near USB-C)
  (module "Package_TO_SOT_SMD:SOT-143" (at 10 8 0) (uuid "mod0002")
    (net "VBUS" "GND" "USB_DP" "USB_DM")
  )

  ;; FB1 - Ferrite bead (VBUS filter)
  (module "Inductor_SMD:L_0603_1608Metric" (at 10 5 0) (uuid "mod0003")
    (net "VBUS" "VBUS_FILTERED")
  )

  ;; U7 - STPMIC1 (power management, near USB)
  (module "Package_DFN_QFN:QFN-24-1EP_4x4mm_P0.5mm_EP2.6x2.6mm" (at 15 10 0) (uuid "mod0004")
    (net "VBUS" "VDD_3V3" "VDD_1V8" "VDD_1V1" "GND" "PMIC_SDA" "PMIC_SCL" "VBAT_CR2032")
  )

  ;; L1 - Buck inductor (adjacent to PMIC)
  (module "Inductor_SMD:L_NRP4018T4R7MJRF" (at 15 14 0) (uuid "mod0005")
    (net "VDD_3V3" "BUCK_SW")
  )

  ;; U1 - STM32L562 (center of board)
  (module "Package_DFN_QFN:UFQFPN-48-1EP_6x6mm_P0.4mm_EP4.4x4.4mm" (at 22 10 0) (uuid "mod0006")
    (net "VDD_3V3" "GND" "VBAT_CR2032" "SE_SDA" "SE_SCL" "SE_IRQ" "nSE_RST"
         "NFC_NSS" "NFC_SCK" "NFC_MISO" "NFC_MOSI" "NFC_IRQ" "nNFC_RST"
         "FP_TX" "FP_RX" "nFP_RST" "FP_IRQ"
         "BLE_TX" "BLE_RX" "nBLE_RST" "BLE_MODE"
         "FLASH_NSS" "FLASH_SCK" "FLASH_MISO" "FLASH_MOSI" "FLASH_D2" "FLASH_D3" "nFLASH_WP"
         "LED_RED" "LED_GREEN" "LED_BLUE"
         "USB_DP" "USB_DM" "VBUS" "SWDIO" "SWCLK" "nRST" "BOOT0")
  )

  ;; U2 - A71CH (near MCU, I2C bus)
  (module "Package_DFN_QFN:HVQFN-32-1EP_5x5mm_P0.5mm_EP3.55x3.55mm" (at 30 6 0) (uuid "mod0007")
    (net "VDD_3V3" "GND" "SE_SDA" "SE_SCL" "nSE_RST" "SE_IRQ")
  )

  ;; U6 - MX25R1635F QSPI Flash (near MCU)
  (module "Package_SON:USON-8_4x4mm_P0.5mm_EP2.1x3.1mm" (at 30 10 0) (uuid "mod0008")
    (net "VDD_3V3" "GND" "FLASH_NSS" "FLASH_SCK" "FLASH_MISO" "FLASH_MOSI" "FLASH_D2" "FLASH_D3" "nFLASH_WP")
  )

  ;; U3 - PN7150 NFC (below MCU)
  (module "Package_DFN_QFN:HVQFN-40-1EP_6x6mm_P0.5mm_EP4.4x4.4mm" (at 22 16 0) (uuid "mod0009")
    (net "VDD_3V3" "GND" "NFC_NSS" "NFC_SCK" "NFC_MISO" "NFC_MOSI" "NFC_IRQ" "nNFC_RST" "NFC_ANT_P" "NFC_ANT_N" "VBAT_CR2032")
  )

  ;; U4 - FPC1025 Fingerprint (right side)
  (module "Sensor_Fingerprint:FPC1025_LGA57" (at 35 10 0) (uuid "mod0010")
    (net "VDD_3V3" "VDD_1V8" "GND" "FP_TX" "FP_RX" "nFP_RST" "FP_IRQ")
  )

  ;; U5 - nRF52833 BLE (right side, upper)
  (module "Package_DFN_QFN:QFN-48-1EP_6x6mm_P0.4mm_EP4.6x4.6mm" (at 38 4 0) (uuid "mod0011")
    (net "VDD_3V3" "VDD_1V1" "VDD_NRF" "GND" "BLE_TX" "BLE_RX" "nBLE_RST" "ANT_BLE" "SWDIO_NRF" "SWCLK_NRF")
  )

  ;; BT1 - CR2032 holder (bottom right)
  (module "Battery:Battery_Holder_CR2032_Linx_BAT-HLD-001-THM" (at 38 16 0) (uuid "mod0012")
    (net "VBAT_CR2032" "GND")
  )

  ;; SW1 - Touch button (bottom center)
  (module "Button_Switch_SMD:SW_Push_5mm_SKQGADE010" (at 30 18 0) (uuid "mod0013")
    (net "VDD_3V3" "GND" "BTN_USER")
  )

  ;; D2-D4 - Status LEDs (near MCU, top)
  (module "LED_SMD:LED_0402_1005Metric" (at 22 4 0) (uuid "mod0014")
    (net "LED_RED" "GND")
  )
  (module "LED_SMD:LED_0402_1005Metric" (at 24 4 0) (uuid "mod0015")
    (net "LED_GREEN" "GND")
  )
  (module "LED_SMD:LED_0402_1005Metric" (at 26 4 0) (uuid "mod0016")
    (net "LED_BLUE" "GND")
  )

  ;; Y1 - 32.768 kHz crystal (MCU)
  (module "Crystal:Crystal_ECS-32x7mm-2Pin" (at 18 4 0) (uuid "mod0017")
    (net "OSC32_IN" "OSC32_OUT" "GND")
  )

  ;; Y2 - 32.768 kHz crystal (nRF)
  (module "Crystal:Crystal_DS10-2Pin_3.2x1.5mm" (at 42 6 0) (uuid "mod0018")
    (net "XOSC32_NRF_IN" "XOSC32_NRF_OUT" "GND")
  )

  ;; Y3 - 32 MHz crystal (nRF)
  (module "Crystal:Crystal_SMD_HC49-SD" (at 42 2 0) (uuid "mod0019")
    (net "XOSC32M_NRF_IN" "XOSC32M_NRF_OUT" "GND")
  )

  ;; ========================================
  ;; BLE ANTENNA (meandered inverted-F, bottom layer)
  ;; ========================================
  (gr_line (start 38 0) (end 38 3) (layer "B.Cu") (width 0.2) (uuid "ant1"))
  (gr_line (start 38 3) (end 40 3) (layer "B.Cu") (width 0.2) (uuid "ant2"))
  (gr_line (start 40 3) (end 40 1) (layer "B.Cu") (width 0.2) (uuid "ant3"))
  (gr_line (start 40 1) (end 42 1) (layer "B.Cu") (width 0.2) (uuid "ant4"))
  (gr_line (start 42 1) (end 42 3) (layer "B.Cu") (width 0.2) (uuid "ant5"))
  (gr_line (start 42 3) (end 44 3) (layer "B.Cu") (width 0.2) (uuid "ant6"))

  ;; BLE antenna ground plane (bottom layer, surrounding antenna)
  ;; Keepout: no copper within 5mm of antenna traces

  ;; ========================================
  ;; NFC ANTENNA (circular loop, bottom layer, 30mm diameter)
  ;; ========================================
  (gr_arc (start 22 14) (mid 37 14) (end 22 -1) (layer "B.Cu") (width 0.8) (uuid "nfc1"))
  ;; Second arc to complete circle
  (gr_arc (start 22 -1) (mid 7 14) (end 22 14) (layer "B.Cu") (width 0.8) (uuid "nfc2"))
  ;; Feed points
  (gr_line (start 22 16) (end 22 14.5) (layer "B.Cu") (width 0.8) (uuid "nfc3"))  ;; ANT_P
  (gr_line (start 22 13.5) (end 22 12) (layer "B.Cu") (width 0.8) (uuid "nfc4"))  ;; ANT_N

  ;; ========================================
  ;; DIMENSION ANNOTATIONS
  ;; ========================================
  (gr_text "44mm" (at 22 -2) (layer "Eco2.User") (uuid "dim1"))
  (gr_text "20mm" (at -3 10) (layer "Eco2.User") (uuid "dim2"))
  (gr_text "CyberGuard v1.0" (at 22 10) (layer "F.SilkS") (uuid "silkscreen1"))
  (gr_text "KEYCHAIN HOLE ∅4mm" (at 22 3) (layer "Eco2.User") (uuid "dim3"))
  (gr_text "NFC ANT ∅30mm" (at 22 14) (layer "Eco2.User") (uuid "dim4"))
  (gr_text "BLE ANT (MIFA)" (at 40 1) (layer "Eco2.User") (uuid "dim5"))
  (gr_text "6-LAYER 1.0mm" (at 22 22) (layer "Eco2.User") (uuid "dim6"))
  (gr_text "ENIG SURFACE FINISH" (at 22 23) (layer "Eco2.User") (uuid "dim7"))

  ;; ========================================
  ;; DESIGN RULES
  ;; ========================================
  (setup
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.1)
    (grid_origin 0 0)
    (pcbplotparams
      (layerselection "0x0000010fc800017")
      (disableapertmacros false)
      (usegerberextensions true)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (dashed_line_dash_ratio 12)
      (dashed_line_gap_ratio 3)
      (svgprecision 4)
      (plotreference true)
      (plotvalue true)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk true)
      (outputformat 1)
      (mirror false)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )
)