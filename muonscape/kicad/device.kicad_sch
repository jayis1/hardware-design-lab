  ; ---- Wires / net connections ----
  ; SPI1 between STM32 and FPGA
  (wire (pts (xy 120 90) (xy 220 90))  (net 8))   ; SCK
  (wire (pts (xy 120 95) (xy 220 95))  (net 9))   ; MISO
  (wire (pts (xy 120 100)(xy 220 100))(net 10))  ; MOSI
  (wire (pts (xy 120 105)(xy 220 105))(net 11))  ; CRESET
  (wire (pts (xy 80 105) (xy 220 110))(net 12))  ; CDONE
  (wire (pts (xy 80 110) (xy 220 115))(net 13))  ; IRQ

  ; I2C1 to all peripherals
  (wire (pts (xy 120 110)(xy 300 155))(net 15))  ; SCL
  (wire (pts (xy 120 115)(xy 300 160))(net 16))  ; SDA

  ; SiPM bias DAC VOUTA to SiPM anodes
  (wire (pts (xy 120 165)(xy 180 215))(net 7))   ; VOUTA -> SiPM bias rail

  ; SiPM cathode to ASIC input
  (wire (pts (xy 220 215)(xy 120 210))(net 84))

  ; ASIC LVDS to FPGA
  (wire (pts (xy 120 220)(xy 180 110))(net 87)) ; HIT_0+
  (wire (pts (xy 120 225)(xy 180 115))(net 88)) ; HIT_0-

  ; GPS UART
  (wire (pts (xy 220 155)(xy 80 75))  (net 17))  ; TX (routed around)
  (wire (pts (xy 220 160)(xy 80 80))  (net 18))  ; RX
  (wire (pts (xy 220 165)(xy 80 120))(net 19))  ; PPS -> EXTI

  ; Wi-Fi SPI3
  (wire (pts (xy 300 90) (xy 350 90)) (net 23))  ; SCK
  (wire (pts (xy 300 95) (xy 350 95)) (net 24))  ; MISO
  (wire (pts (xy 300 100)(xy 350 100))(net 25))  ; MOSI

