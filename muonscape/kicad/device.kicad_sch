  (wire (pts (xy 370 95) (xy 80 95))  (net 53))  ; D15
  (wire (pts (xy 370 100)(xy 80 100))(net 54))  ; A0
  (wire (pts (xy 370 110)(xy 80 110))(net 71))  ; NWE
  (wire (pts (xy 370 115)(xy 80 115))(net 72))  ; NOE

  ; Charger PWM
  (wire (pts (xy 370 160)(xy 80 250))(net 76))  ; TIM8_CH1

