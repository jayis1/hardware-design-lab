    (pad "2" smd rect (size 0.8 0.8) (at 150.75 30 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND"))
  )

  ; ---- User button ----
  (footprint "Button_Switch_SMD:SW_SPST_B3U-1000P" (layer "F.Cu")
    (at 10 60)
    (property "Reference" "SW1" (at 10 56 0))
    (property "Value" "USER" (at 10 64 0))
    (property "Author" "jayis1" (at 10 60 0))
    (pad "1" smd rect (size 1.5 1.0) (at 8.5 60 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 30 "BTN_USER"))
    (pad "2" smd rect (size 1.5 1.0) (at 11.5 60 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND"))
  )

  ; ---- I2C pull-ups ----
  (footprint "Resistor_SMD:R_0402_1005Metric" (layer "F.Cu")
    (at 70 70)
    (property "Reference" "R1" (at 70 68 0))
    (property "Value" "4k7" (at 70 72 0))
    (property "Author" "jayis1" (at 70 70 0))
    (pad "1" smd roundrect (size 0.6 0.5) (at 69.5 70 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VCC_3V3"))
    (pad "2" smd roundrect (size 0.6 0.5) (at 70.5 70 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "I2C1_SCL"))
  )
  (footprint "Resistor_SMD:R_0402_1005Metric" (layer "F.Cu")
    (at 75 70)
    (property "Reference" "R2" (at 75 68 0))
    (property "Value" "4k7" (at 75 72 0))
    (property "Author" "jayis1" (at 75 70 0))
    (pad "1" smd roundrect (size 0.6 0.5) (at 74.5 70 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VCC_3V3"))
    (pad "2" smd roundrect (size 0.6 0.5) (at 75.5 70 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "I2C1_SDA"))
  )

  ; ---- Boost inductor for SiPM bias ----
  (footprint "Inductor_SMD:L_1008_2520Metric" (layer "F.Cu")
    (at 55 85)
    (property "Reference" "L1" (at 55 83 0))
    (property "Value" "22uH" (at 55 87 0))
    (property "Author" "jayis1" (at 55 85 0))
    (pad "1" smd rect (size 2.0 2.0) (at 53.5 85 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "VBATT_26V4"))
    (pad "2" smd rect (size 2.0 2.0) (at 56.5 85 0) (layers "F.Cu" "F.Paste" "F.Mask") (net 25 "SIPM_BIAS"))
  )

  ; ---- Tracks (representative routing) ----
  ; SPI1 SCK: U1 pin 10 -> U2 pin 10
  (segment (start 41.5 47.5) (end 86 50) (width 0.2) (layer "F.Cu") (net 7))
  ; SPI1 MISO: U1 pin 11 -> U2 pin 11
  (segment (start 41.5 48) (end 86 50.5) (width 0.2) (layer "F.Cu") (net 8))
  ; SPI1 MOSI: U1 pin 12 -> U2 pin 12
  (segment (start 41.5 48.5) (end 86 51) (width 0.2) (layer "F.Cu") (net 9))
  ; I2C SCL: U1 pin 25 -> U3, U6, U9
  (segment (start 41.5 55) (end 46.5 79.3) (width 0.2) (layer "F.Cu") (net 13))
  (segment (start 46.5 79.3) (end 97 93.4) (width 0.2) (layer "F.Cu") (net 13))
  (segment (start 46.5 79.3) (end 126.5 80) (width 0.2) (layer "F.Cu") (net 13))
  ; I2C SDA: U1 pin 26 -> U3, U6, U9
  (segment (start 41.5 55.5) (end 46.5 79.95) (width 0.2) (layer "F.Cu") (net 14))
  (segment (start 46.5 79.95) (end 96.6 93.4) (width 0.2) (layer "F.Cu") (net 14))
  (segment (start 46.5 79.95) (end 126.5 80.5) (width 0.2) (layer "F.Cu") (net 14))
  ; FMC D0: U1 pin 50 -> U8 pin 3
  (segment (start 58.5 50) (end 44.8 93.1) (width 0.2) (layer "F.Cu") (net 17))
  ; LVDS HIT_0+: U2 pin 35 -> U9 pin 70
  (segment (start 94 50) (end 93 106.6) (width 0.18) (layer "F.Cu") (net 23))
  ; LVDS HIT_0-: U2 pin 36 -> U9 pin 71
  (segment (start 94 50.5) (end 93.4 106.6) (width 0.18) (layer "F.Cu") (net 24))
  ; SIPM bias: U3 pin 8 -> L1 pin 2 -> SiPM anode -> U9 input
  (segment (start 46.5 82.5) (end 56.5 85) (width 0.8) (layer "F.Cu") (net 25))
  (segment (start 56.5 85) (end 97 30) (width 0.8) (layer "F.Cu") (net 25))
  (segment (start 97 30) (end 83 95) (width 0.8) (layer "F.Cu") (net 25))
  ; GPS PPS: U4 pin 5 -> U1 EXTI
  (segment (start 96 84) (end 41.5 110) (width 0.2) (layer "F.Cu") (net 15))
  ; LED_STATUS: U1 pin 90 -> D2 pin 1
  (segment (start 41.5 50) (end 139.25 30) (width 0.2) (layer "F.Cu") (net 26))
  ; VCC_3V3 power rail (wide trace)
  (segment (start 5 5) (end 41.5 43) (width 0.8) (layer "In1.Cu") (net 2))
  (segment (start 41.5 43) (end 86 45.5) (width 0.8) (layer "In1.Cu") (net 2))
  (segment (start 86 45.5) (end 122 45) (width 0.8) (layer "In1.Cu") (net 2))
  ; GND power rail (In2.Cu plane)
  (segment (start 0 0) (end 160 0) (width 0.8) (layer "In2.Cu") (net 1))
  (segment (start 0 0) (end 0 120) (width 0.8) (layer "In2.Cu") (net 1))
  (segment (start 160 0) (end 160 120) (width 0.8) (layer "In2.Cu") (net 1))
  (segment (start 0 120) (end 160 120) (width 0.8) (layer "In2.Cu") (net 1))
  ; VCC_1V2 power rail
  (segment (start 86 46) (end 84.25 45) (width 0.8) (layer "In1.Cu") (net 4))
  ; VBATT rail
  (segment (start 127.5 96) (end 53.5 85) (width 1.0) (layer "In1.Cu") (net 6))

  ; ---- Vias ----
  (via (at 70 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 80 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 100 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 120 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 60 80) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 110 80) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))

  ; ---- Zones ----
  (zone (net 1) (net_name "GND") (layer "B.Cu") (tstamp 0)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.4) (thermal_bridge_width 0.5))
    (polygon
      (pts (xy 0 0) (xy 160 0) (xy 160 120) (xy 0 120))
    )
  )
  (zone (net 2) (net_name "VCC_3V3") (layer "In1.Cu") (tstamp 1)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.4) (thermal_bridge_width 0.5))
    (polygon
      (pts (xy 5 5) (xy 155 5) (xy 155 70) (xy 5 70))
    )
  )
  (zone (net 4) (net_name "VCC_1V2") (layer "In2.Cu") (tstamp 2)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.4) (thermal_bridge_width 0.5))
    (polygon
      (pts (xy 80 40) (xy 100 40) (xy 100 55) (xy 80 55))
    )
  )

  ; ---- Silkscreen text ----
  (gr_text "MûonScape PCB" (at 80 10) (layer "F.SilkS")
    (effects (font (size 3 3) bold) (justify center)))
  (gr_text "jayis1 — (c) 2026 — CERN-OHL-S v2" (at 80 14)
    (layer "F.SilkS") (effects (font (size 1.5 1.5)) (justify center)))
  (gr_text "Rev 1.0" (at 150 115) (layer "F.SilkS")
    (effects (font (size 1.5 1.5)) (justify right)))
  (gr_text "STM32H723" (at 50 50) (layer "F.SilkS")
    (effects (font (size 1.2 1.2))))
  (gr_text "iCE40-UP5K" (at 90 50) (layer "F.SilkS")
    (effects (font (size 1.2 1.2))))
  (gr_text "NUS32toA" (at 90 100) (layer "F.SilkS")
    (effects (font (size 1.2 1.2))))
  (gr_text "pSRAM 8MB" (at 50 100) (layer "F.SilkS")
