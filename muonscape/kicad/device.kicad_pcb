(kicad_pcb
  (version 20211014)
  (generator "muonscape-pcb-gen")
  (generator_version "1.0")
  (general (thickness 1.6) (legacy_teardrops no))
  (paper "A3")
  (title_block
    (title "MûonScape — Portable Cosmic-Ray Muon Tomography Imager")
    (date "2026-07-05")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "Copyright (c) 2026 jayis1")
    (comment 3 "License: CERN-OHL-S v2")
    (comment 4 "160x120mm 4-layer, 192 SiPM + STM32H723 + iCE40")
  )

  ; ---- Layers ----
  (layer "F.Cu" signal)
  (layer "In1.Cu" signal)
  (layer "In2.Cu" signal)
  (layer "B.Cu" signal)
  (layer "F.SilkS" silk "Front Silk Screen")
  (layer "B.SilkS" silk "Back Silk Screen")
  (layer "F.Mask" mask)
  (layer "B.Mask" mask)
  (layer "F.Paste" paste)
  (layer "B.Paste" paste)
  (layer "F.Fab" fab)
  (layer "B.Fab" fab)
  (layer "Edge.Cuts" user)
  (layer "F.CrtYd" user "Front Courtyard")
  (layer "B.CrtYd" user "Back Courtyard")

  ; ---- Setup ----
  (setup
    (stackup
      (layer "F.Cu" (type copper) (thickness 0.035))
      (layer "dielectric 1" (type core) (thickness 0.2) (material "FR4"))
      (layer "In1.Cu" (type copper) (thickness 0.035))
      (layer "dielectric 2" (type core) (thickness 1.0) (material "FR4"))
      (layer "In2.Cu" (type copper) (thickness 0.035))
      (layer "dielectric 3" (type core) (thickness 0.2) (material "FR4"))
      (layer "B.Cu" (type copper) (thickness 0.035))
      (copper_finish "ENIG")
      (thickness 1.6)
    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.05)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (usegerberextensions true)
      (usegerberattributes true)
    )
  )

  ; ---- Net definitions ----
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC_3V3")
  (net 3 "VCC_5V")
  (net 4 "VCC_1V2")
  (net 5 "VCC_15V7")
  (net 6 "VBATT_26V4")
  (net 7 "SPI1_SCK")
  (net 8 "SPI1_MISO")
  (net 9 "SPI1_MOSI")
  (net 10 "FPGA_CRESET")
  (net 11 "FPGA_CDONE")
  (net 12 "FPGA_IRQ")
  (net 13 "I2C1_SCL")
  (net 14 "I2C1_SDA")
  (net 15 "GPS_PPS")
  (net 16 "WIFI_CS")
  (net 17 "FMC_D0")
  (net 18 "FMC_D15")
  (net 19 "FMC_A0")
  (net 20 "FMC_NWE")
  (net 21 "FMC_NOE")
  (net 22 "TIM8_CH1_PWM")
  (net 23 "LVDS_HIT_0+")
  (net 24 "LVDS_HIT_0-")
  (net 25 "SIPM_BIAS")
  (net 26 "LED_STATUS")
  (net 27 "LED_FAULT")
  (net 28 "LED_GPS")
  (net 29 "LED_WIFI")
  (net 30 "BTN_USER")

  ; ---- Board edge ----
  (gr_line (start 0 0) (end 160 0) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 160 0) (end 160 120) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 160 120) (end 0 120) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 120) (end 0 0) (layer "Edge.Cuts") (width 0.15))

