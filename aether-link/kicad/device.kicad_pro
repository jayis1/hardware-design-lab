    "custom_rules": [
      {
        "name": "PCIe_intra_pair_skew",
        "constraint": "skew",
        "max": "0.15mil",
        "condition": "A.NetClass == 'PCIe_Gen4'"
      },
      {
        "name": "QSFP_intra_pair_skew",
        "constraint": "skew",
        "max": "0.08mil",
        "condition": "A.NetClass == 'QSFP28_100G'"
      },
      {
        "name": "DDR4_DQS_skew",
        "constraint": "skew",
        "max": "2ps",
        "condition": "A.NetName == 'DDR4_A_DQS0_P' || A.NetName == 'DDR4_A_DQS0_N'"
      },
      {
        "name": "DDR4_CLK_to_ADDR_skew",
        "constraint": "skew",
        "max": "5ps",
        "condition": "A.NetName == 'DDR4_A_CK0_P' || A.NetName == 'DDR4_A_CK0_N'"
      },
      {
        "name": "PCIe_max_length",
        "constraint": "length",
        "max": "101.6mm",
        "condition": "A.NetClass == 'PCIe_Gen4'"
      },
      {
        "name": "QSFP_max_length",
        "constraint": "length",
        "max": "76.2mm",
        "condition": "A.NetClass == 'QSFP28_100G'"
      },
      {
        "name": "DDR4_max_length",
        "constraint": "length",
        "max": "63.5mm",
        "condition": "A.NetClass == 'DDR4_3200'"
      },
      {
        "name": "PCIe_via_count",
        "constraint": "via_count",
        "max": "2",
        "condition": "A.NetClass == 'PCIe_Gen4'"
      },
      {
        "name": "QSFP_via_count",
        "constraint": "via_count",
        "max": "2",
        "condition": "A.NetClass == 'QSFP28_100G'"
      },
      {
        "name": "DDR4_via_count",
        "constraint": "via_count",
        "max": "1",
        "condition": "A.NetClass == 'DDR4_3200'"
      },
      {
        "name": "Power_plane_clearance",
        "constraint": "clearance",
        "min": "1.0mm",
        "condition": "A.NetClass == 'Power' && B.NetClass != 'Power'"
      },
      {
        "name": "Diff_pair_gap_to_other",
        "constraint": "clearance",
        "min": "0.75mm",
        "condition": "A.NetClass == 'PCIe_Gen4' && B.NetClass != 'PCIe_Gen4'"
      }
    ]
  },
