(kicad_pcb
  (version 20240101)
  (generator "planner")
  
  (general
    (thickness 1.6)
    (board_outline_rect 80.0 60.0 1.5)
  )

  (title_block
    (title "RideCore 48V/200A PMSM Motor Controller")
    (date "2026-06-14")
    (rev "1.0")
    (company "RideCore Open Hardware")
  )

  ;; ============================================================
  ;; LAYER STACKUP
  ;; ============================================================
  (stackup
    (layer 0  "F.Cu"      signal  copper_weight 1oz)
    (layer 1  "In1.Cu"    ground  copper_weight 1oz  material "Isola 370HR" dielectric 4.2)
    (layer 2  "In2.Cu"    signal  copper_weight 1oz)
    (layer 3  "In3.Cu"    power   copper_weight 2oz  material "Isola 370HR" dielectric 4.2)
    (layer 4  "In4.Cu"    ground  copper_weight 1oz)
    (layer 5  "B.Cu"      signal  copper_weight 1oz)
    (dielectric_between 0 1 thickness 0.10 material "FR-4 prepreg")
    (dielectric_between 1 2 thickness 0.36 material "FR-4 core")
    (dielectric_between 2 3 thickness 0.10 material "FR-4 prepreg")
    (dielectric_between 3 4 thickness 0.36 material "FR-4 core")
    (dielectric_between 4 5 thickness 0.10 material "FR-4 prepreg")
    (soldermask_top  color "Black")
    (soldermask_bottom color "Black")
    (silkscreen_top  color "White")
    (silkscreen_bottom color "White")
    (surface_finish "ENIG" Au_thickness 0.05um Ni_thickness 3um)
  )

  ;; ============================================================
  ;; BOARD OUTLINE
  ;; ============================================================
  (outline
    (rect 0 0 80.0 60.0 1.5)
  )

  ;; ============================================================
  ;; MOUNTING HOLES (4× M3)
  ;; ============================================================
  (pad (at 3.5 3.5)   shape circle size 3.2 drill 3.2 layers "*.Cu" net "GND" plated)
  (pad (at 76.5 3.5)  shape circle size 3.2 drill 3.2 layers "*.Cu" net "GND" plated)
  (pad (at 3.5 56.5)  shape circle size 3.2 drill 3.2 layers "*.Cu" net "GND" plated)
  (pad (at 76.5 56.5) shape circle size 3.2 drill 3.2 layers "*.Cu" net "GND" plated)

  ;; ============================================================
  ;; HEATSINK MOUNTING (4× M2)
  ;; ============================================================
  (pad (at 35 35)  shape circle size 2.2 drill 2.0 layers "*.Cu" net "GND" plated)
  (pad (at 45 35)  shape circle size 2.2 drill 2.0 layers "*.Cu" net "GND" plated)
  (pad (at 35 45)  shape circle size 2.2 drill 2.0 layers "*.Cu" net "GND" plated)
  (pad (at 45 45)  shape circle size 2.2 drill 2.0 layers "*.Cu" net "GND" plated)

  ;; ============================================================
  ;; COMPONENT PLACEMENT (approximate coordinates, mm)
  ;; ============================================================
  
  ;; --- Logic Zone (left half) ---
  (footprint (ref "U1")  (at 25 30)  rotation 0   layer "F.Cu"  value "STM32G474CEU6")
  (footprint (ref "U2")  (at 15 12)  rotation 0   layer "F.Cu"  value "TPS6521801RSL")
  (footprint (ref "U3")  (at 40 12)  rotation 0   layer "F.Cu"  value "MCP2518FD-I/ST")
  (footprint (ref "U4")  (at 55 12)  rotation 0   layer "F.Cu"  value "TJA1463AT/1J")
  (footprint (ref "U5")  (at 15 52)  rotation 0   layer "F.Cu"  value "nRF52832-CIAA")
  (footprint (ref "U6")  (at 40 52)  rotation 0   layer "F.Cu"  value "W25Q128JVSIM")
  (footprint (ref "U16") (at 8 45)   rotation 0   layer "F.Cu"  value "AT30TS74-MA8M-T")
  (footprint (ref "Y1")  (at 20 20)  rotation 0   layer "F.Cu"  value "8MHz Crystal")
  (footprint (ref "Y2")  (at 15 45)  rotation 0   layer "F.Cu"  value "32MHz Crystal")
  (footprint (ref "SW1") (at 30 8)   rotation 0   layer "F.Cu"  value "Reset Switch")
  (footprint (ref "LED1") (at 5 8)  rotation 0   layer "F.Cu"  value "Green LED")
  (footprint (ref "LED2") (at 5 12) rotation 0   layer "F.Cu"  value "Red LED")
  (footprint (ref "J3")  (at 40 58)  rotation 180 layer "F.Cu"  value "USB-C 2.0")
  (footprint (ref "J4")  (at 60 2)   rotation 0   layer "F.Cu"  value "Hall Sensor 6-pin")

  ;; --- Power Zone (right half) ---
  (footprint (ref "U10") (at 25 35) rotation 0 layer "F.Cu"  value "ADuM3223 A")
  (footprint (ref "U11") (at 35 35) rotation 0 layer "F.Cu"  value "ADuM3223 B")
  (footprint (ref "U12") (at 45 35) rotation 0 layer "F.Cu"  value "ADuM3223 C")

  ;; --- Isolation slot (1mm milled) between x=50 and x=51 ---
  (keepout (type slot) (at 50.5 0) (width 1.0) (height 60.0) (layers "F.Cu" "In1.Cu" "In2.Cu" "In3.Cu" "In4.Cu" "B.Cu"))

  (footprint (ref "U7")  (at 57 30) rotation 0  layer "F.Cu"  value "IRS2186 Phase A")
  (footprint (ref "U8")  (at 63 30) rotation 0  layer "F.Cu"  value "IRS2186 Phase B")
  (footprint (ref "U9")  (at 69 30) rotation 0  layer "F.Cu"  value "IRS2186 Phase C")

  ;; MOSFETs (power stage, centered with copper pours)
  (footprint (ref "Q1")  (at 57 42) rotation 0  layer "F.Cu"  value "IPT015N10N5 High A")
  (footprint (ref "Q2")  (at 57 48) rotation 0  layer "F.Cu"  value "IPT015N10N5 Low A")
  (footprint (ref "Q3")  (at 63 42) rotation 0  layer "F.Cu"  value "IPT015N10N5 High B")
  (footprint (ref "Q4")  (at 63 48) rotation 0  layer "F.Cu"  value "IPT015N10N5 Low B")
  (footprint (ref "Q5")  (at 69 42) rotation 0  layer "F.Cu"  value "IPT015N10N5 High C")
  (footprint (ref "Q6")  (at 69 48) rotation 0  layer "F.Cu"  value "IPT015N10N5 Low C")

  ;; Current sense amps
  (footprint (ref "U13") (at 57 54) rotation 0  layer "F.Cu"  value "INA241A Phase A")
  (footprint (ref "U14") (at 63 54) rotation 0  layer "F.Cu"  value "INA241A Phase B")
  (footprint (ref "U15") (at 69 54) rotation 0  layer "F.Cu"  value "INA241A Phase C")

  ;; Shunt resistors
  (footprint (ref "R7")  (at 58 42) rotation 0  layer "F.Cu"  value "0.5mΩ Shunt A")
  (footprint (ref "R8")  (at 64 42) rotation 0  layer "F.Cu"  value "0.5mΩ Shunt B")
  (footprint (ref "R9")  (at 70 42) rotation 0  layer "F.Cu"  value "0.5mΩ Shunt C")

  ;; Bulk capacitors (near power input)
  (footprint (ref "C1")  (at 52 8) rotation 0  layer "F.Cu"  value "470µF 63V")
  (footprint (ref "C2")  (at 55 8) rotation 0  layer "F.Cu"  value "470µF 63V")
  (footprint (ref "C3")  (at 58 8) rotation 0  layer "F.Cu"  value "470µF 63V")
  (footprint (ref "C4")  (at 61 8) rotation 0  layer "F.Cu"  value "470µF 63V")

  ;; TVS
  (footprint (ref "D1")  (at 52 15) rotation 0  layer "F.Cu"  value "SMBJ58A")
  (footprint (ref "D2")  (at 52 20) rotation 0  layer "F.Cu"  value "SS34 Schottky")

  ;; Phase + HV connector (right edge)
  (footprint (ref "J1")  (at 78 15) rotation 90  layer "F.Cu"  value "Phase/HV 4-pin")
  ;; CAN connector (bottom edge)
  (footprint (ref "J2")  (at 10 58) rotation 0  layer "F.Cu"  value "CAN 5-pin")

  ;; Gate resistors (near MOSFETs)
  (footprint (ref "R1")  (at 57 39) rotation 90  layer "F.Cu"  value "10Ω Gate A-Hi")
  (footprint (ref "R2")  (at 57 51) rotation 90  layer "F.Cu"  value "10Ω Gate A-Lo")
  (footprint (ref "R3")  (at 63 39) rotation 90  layer "F.Cu"  value "10Ω Gate B-Hi")
  (footprint (ref "R4")  (at 63 51) rotation 90  layer "F.Cu"  value "10Ω Gate B-Lo")
  (footprint (ref "R5")  (at 69 39) rotation 90  layer "F.Cu"  value "10Ω Gate C-Hi")
  (footprint (ref "R6")  (at 69 51) rotation 90  layer "F.Cu"  value "10Ω Gate C-Lo")

  ;; ============================================================
  ;; COPPER POURS
  ;; ============================================================
  (zone (net "GND") (layer "In1.Cu") (pour solid) (keepout_none))
  (zone (net "GND") (layer "In4.Cu") (pour solid) (keepout_none))
  (zone (net "HV_BUS") (layer "In3.Cu") (pour solid) 
    (polygon 51 0 80 28)  ;; right half, top section
  )
  (zone (net "PH_A") (layer "In3.Cu") (pour solid)
    (polygon 51 28 56 42)
  )
  (zone (net "PH_B") (layer "In3.Cu") (pour solid)
    (polygon 57 28 62 42)
  )
  (zone (net "PH_C") (layer "In3.Cu") (pour solid)
    (polygon 63 28 68 42)
  )

  ;; ============================================================
  ;; KEEPOUT ZONES
  ;; ============================================================
  (keepout (type antenna) (at 66 50) (width 15) (height 10) (layers "F.Cu" "In1.Cu" "In2.Cu" "In3.Cu" "In4.Cu" "B.Cu")
    (comment "BLE 2.4GHz antenna keepout zone - no copper on any layer"))

  ;; ============================================================
  ;; THERMAL VIA ARRAYS (under MOSFET drain pads)
  ;; ============================================================
  (via_array (ref "Q1") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "HV_BUS" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)
  (via_array (ref "Q2") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "PH_A" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)
  (via_array (ref "Q3") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "HV_BUS" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)
  (via_array (ref "Q4") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "PH_B" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)
  (via_array (ref "Q5") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "HV_BUS" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)
  (via_array (ref "Q6") count 4 drill 0.5 pad 1.0 pattern 2x2 pitch 1.27 net "PH_C" layers "In3.Cu" "In4.Cu" "B.Cu" filled epoxy_copper_capped)

  ;; QFN thermal pads (U1, U5)
  (via_array (ref "U1") count 9 drill 0.3 pad 0.6 pattern 3x3 pitch 1.0 net "GND" layers "In1.Cu" filled epoxy_copper_capped)
  (via_array (ref "U5") count 9 drill 0.3 pad 0.6 pattern 3x3 pitch 1.0 net "GND" layers "In1.Cu" filled epoxy_copper_capped)

  ;; GND stitching vias (perimeter)
  (stitching (net "GND") (drill 0.3) (pad 0.6) (pitch 2.5) (layers "F.Cu" "In1.Cu" "In4.Cu" "B.Cu")
    (path 0 0 80 0)    ;; top edge
    (path 80 0 80 60)  ;; right edge
    (path 80 60 0 60)  ;; bottom edge
    (path 0 60 0 0)    ;; left edge
  )

  ;; ============================================================
  ;; HIGH-SPEED ROUTING CONSTRAINTS
  ;; ============================================================
  (diff_pair (net "USB_DP" "USB_DM") (layer "F.Cu") (width 0.15) (gap 0.10) (impedance 90) (max_skew 0.5mm))
  (diff_pair (net "CAN_H" "CAN_L") (layer "F.Cu") (width 0.20) (gap 0.15) (impedance 120) (max_skew 1.0mm))
  (rf_trace (net "ANT_RF") (layer "F.Cu") (width 0.38) (impedance 50) (keepout 5mm))
  (length_match (group "PWM_HIGH") (nets "PWM_A_HIGH" "PWM_B_HIGH" "PWM_C_HIGH") (tolerance 1.0mm))
  (length_match (group "PWM_LOW") (nets "PWM_A_LOW" "PWM_B_LOW" "PWM_C_LOW") (tolerance 1.0mm))
)