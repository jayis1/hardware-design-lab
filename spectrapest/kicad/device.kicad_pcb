  ; ----------------------------------------------------------------
  ; Copper zones (ground and power pours)
  ; ----------------------------------------------------------------
  (zone
    (net 1)
    (net_name "GND")
    (layer "In1.Cu")
    (hatch edge 0.5)
    (connect_pads
      (clearance 0.3)
    )
    (min_thickness 0.2)
    (fill yes
      (thermal_gap 0.3)
      (thermal_bridge_width 0.3)
    )
    (polygon
      (pts
        (xy 1 1)
        (xy 119 1)
        (xy 119 79)
        (xy 1 79)
      )
    )
  )

