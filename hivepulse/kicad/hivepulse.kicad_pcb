  (segment (start 52.5 51) (end 70 51) (width 0.25) (layer "F.Cu") (net 13) (tstamp tr000005))
  (segment (start 70 51) (end 75 51) (width 0.25) (layer "F.Cu") (net 13) (tstamp tr000006))
  (segment (start 52.5 51.5) (end 70 51.5) (width 0.25) (layer "F.Cu") (net 14) (tstamp tr000007))
  (segment (start 70 51.5) (end 75 51.5) (width 0.25) (layer "F.Cu") (net 14) (tstamp tr000008))

  ; I2S audio routing (MCU to codec)
  (segment (start 68 45) (end 90 45) (width 0.2) (layer "F.Cu") (net 7) (tstamp tr000010))
  (segment (start 90 45) (end 96 45) (width 0.2) (layer "F.Cu") (net 7) (tstamp tr000011))
  (segment (start 68 45.5) (end 90 45.5) (width 0.2) (layer "F.Cu") (net 6) (tstamp tr000012))
  (segment (start 90 45.5) (end 96 45.5) (width 0.2) (layer "F.Cu") (net 6) (tstamp tr000013))

  ; Power routing (GND plane on In1.Cu, +3V3 on In2.Cu)
  (segment (start 60 52) (end 60 60) (width 0.8) (layer "In2.Cu") (net 2) (tstamp tr000020))
  (segment (start 60 60) (end 100 60) (width 0.8) (layer "In2.Cu") (net 2) (tstamp tr000021))
  (segment (start 100 60) (end 100 52) (width 0.8) (layer "In2.Cu") (net 2) (tstamp tr000022))
  (segment (start 100 52) (end 140 52) (width 0.8) (layer "In2.Cu") (net 2) (tstamp tr000023))

  ; ============================================================================
  ; VIAS
  ; ============================================================================
  (via (at 60 60) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 1) (tstamp v0000001))
  (via (at 100 60) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 1) (tstamp v0000002))
  (via (at 140 60) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 1) (tstamp v0000003))
  (via (at 40 60) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 1) (tstamp v0000004))
  (via (at 20 40) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 1) (tstamp v0000005))

  ; ============================================================================
  ; ZONES (copper pours)
  ; ============================================================================
  (zone (net 1) (net_name "GND") (layer "In1.Cu") (tstamp z0000001)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 179 1) (xy 179 119) (xy 1 119)))
  )
  (zone (net 2) (net_name "+3V3") (layer "In2.Cu") (tstamp z0000002)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 179 1) (xy 179 119) (xy 1 119)))
  )
  (zone (net 1) (net_name "GND") (layer "B.Cu") (tstamp z0000003)
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 1 1) (xy 179 1) (xy 179 119) (xy 1 119)))
  )

  ; ============================================================================
  ; MOUNTING HOLES
  ; ============================================================================
  (footprint "MountingHole:MountingHole_3.2mm"
    (reference "H1") (value "M3")
    (layer "F.Cu") (attr exclude_from_pos_files exclude_from_bom)
    (at 5 5)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "F.Cu" "B.Cu" "F.Mask" "B.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm"
    (reference "H2") (value "M3")
    (layer "F.Cu") (attr exclude_from_pos_files exclude_from_bom)
    (at 175 5)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "F.Cu" "B.Cu" "F.Mask" "B.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm"
    (reference "H3") (value "M3")
    (layer "F.Cu") (attr exclude_from_pos_files exclude_from_bom)
    (at 5 115)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "F.Cu" "B.Cu" "F.Mask" "B.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm"
    (reference "H4") (value "M3")
    (layer "F.Cu") (attr exclude_from_pos_files exclude_from_bom)
    (at 175 115)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "F.Cu" "B.Cu" "F.Mask" "B.Mask"))
  )
)