  (layers
    (0 "F.Cu" signal "Top copper layer — components and high-speed signals")
    (31 "B.Cu" signal "Bottom copper layer — GND pour and slow signals")
    (32 "B.Adhes" user "Bottom adhesive")
    (33 "F.Adhes" user "Top adhesive")
    (34 "B.Paste" user "Bottom solder paste")
    (35 "F.Paste" user "Top solder paste")
