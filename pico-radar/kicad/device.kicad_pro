(kicad_pro (version 20221018)

  (general
    (links 0)
    (no_connects 0)
    (area 0 0 85 55)
    (thickness 1.6)
  )

  (net_class "Default" ""
    (clearance 0.1)
    (trace_width 0.2)
    (via_dia 0.45)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_gap 0.15)
    (diff_pair_width 0.2)
  )

  (net_class "Power" "Power rails: VDD_3V3, VDD_1V8, VDD_1V2, VDD_1V0_RF, VDD_3V0_ANA, VBUS_5V, GND"
    (clearance 0.15)
    (trace_width 0.4)
    (via_dia 0.6)
    (via_drill 0.3)
  )

  (net_class "High-Speed-Diff" "USB D+/D-, Ethernet TX/RX diff pairs"
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.45)
    (via_drill 0.2)
    (diff_pair_gap 0.15)
    (diff_pair_width 0.2)
  )

  (net_class "High-Speed-SE" "QSPI, SPI, RMII single-ended signals"
    (clearance 0.15)
    (trace_width 0.2)
    (via_dia 0.45)
    (via_drill 0.2)
  )

  (design_settings
    (track_widths
      (0.1 0.15 0.2 0.25 0.3 0.4 0.5 0.6 0.8 1.0)
    )
    (via_diameters
      (0.3 0.4 0.45 0.5 0.6 0.8)
    )
    (via_drills
      (0.1 0.15 0.2 0.25 0.3 0.4)
    )
    (diff_pair_gap
      (0.1 0.15 0.2 0.25 0.3)
    )
    (diff_pair_width
      (0.1 0.15 0.18 0.2 0.25)
    )
  )

  (pcbnew
    (last_paths
    )
    (page "A4")
    (layers
      (0 "F.Cu" signal)
      (1 "In1.Cu" signal)
      (2 "In2.Cu" power)
      (3 "In3.Cu" power)
      (4 "In4.Cu" signal)
      (5 "In5.Cu" signal)
      (31 "B.Cu" signal)
      (32 "B.Adhes" user)
      (33 "F.Adhes" user)
      (34 "B.Paste" user)
      (35 "F.Paste" user)
      (36 "B.SilkS" user)
      (37 "F.SilkS" user)
      (38 "B.Mask" user)
      (39 "F.Mask" user)
      (40 "Dwgs.User" user)
      (41 "Cmts.User" user)
      (42 "Eco1.User" user)
      (43 "Eco2.User" user)
      (44 "Edge.Cuts" user)
    )
    (plot
      (outputdirectory "gerbers/")
      (plotformat gerber)
      (layerselection 0x00010fc_ffffffff)
      (useauxorigin false)
      (subtractmaskfromsilk false)
      (mirror false)
      (drillmarks 0)
      (sketchplot false)
      (scale 1)
      (linewidth 0.1)
      (psrefwidth 0.2)
    )
  )

  (schematic
    (last_paths
    )
    (page "A3")
    (edit_order 1)
    (annotate 1)
  )

  (boards
    (board "device.kicad_pcb")
  )

  (sheets
    (sheet "device.kicad_sch")
  )

  (project
    (name "PicoRadar")
    (description "60GHz FMCW Radar Development Platform — IWR6843AOP + STM32H743 + WiFi/BLE + Ethernet + IMU + OLED")
  )
)