  ; ---- Sheet instances & net connections ----
  (sheet (at 40 40) (size 180 120)
    (property "Sheetname" "HydroFluor Main")
    (property "Sheetfile" "device.kicad_sch"))

  ; ---- Component placement & net annotations (summary) ----
  ; U1  STM32L4R9VIT6   @ (60,60)   — main MCU
  ; U2  ADS1256         @ (120,60)  — 24-bit ADC (SPI1)
  ; U3  RFM95W          @ (120,120) — LoRa (SPI2)
  ; U4  BM71            @ (60,120)  — BLE 5 (USART1)
  ; U5  W25Q128         @ (180,60)  — QSPI flash
  ; U6  PCF85263A       @ (180,90)  — RTC (I2C1)
  ; U7  MS5837-02BA     @ (180,120) — depth sensor (I2C1)
  ; U8  LSM6DSO32       @ (220,60)  — IMU (SPI)
  ; U9  DS18B20         @ (220,90)  — temp (1-Wire PB8)
  ; D1-D6 LED 255/280/365/470/590/660nm @ (240,120) excitation array
  ; PD1-PD4 Si photodiodes + bandpass filters @ (260,120)
  ; U10-U13 ADA4625-1   @ (260,60)  — 4× chopper-stabilized preamps
  ; U14   PGA113 (×4)   @ (280,60)  — programmable gain
  ; M1    Peristaltic pump @ (40,160)
  ; BT1   Li-SOCl2 cell @ (40,180)
  ; Csup  1F supercap    @ (60,180)
  ; microSD socket       @ (140,160)

  ; ---- Nets ----
  ; /SPI1_SCK   PA5  -> U2.20  (ADS1256 SCLK)
  ; /SPI1_MISO  PA6  -> U2.22  (ADS1256 DOUT)
  ; /SPI1_MOSI  PA7  -> U2.21  (ADS1256 DIN)
  ; /ADC_CS     PB2  -> U2.19
  ; /ADC_DRDY   PB1  <- U2.18
  ; /SPI2_SCK   PB13 -> U3.5
  ; /SPI2_MISO  PB14 -> U3.3
  ; /SPI2_MOSI  PB15 -> U3.4
  ; /LORA_CS    PB12 -> U3.6
  ; /I2C1_SCL   PB6  -> U6.3, U7.3
  ; /I2C1_SDA   PB7  -> U6.4, U7.4
  ; /UART1_TX   PA9  -> U4.4 (BM71 RX)
  ; /UART1_RX   PA10 <- U4.3 (BM71 TX)
  ; /LED_DRV_255 PA8  -> D1.A (via constant-current MOSFET)
  ; /LED_DRV_280 PA9  -> D2.A
  ; /LED_DRV_365 PA10 -> D3.A
  ; /LED_DRV_470 PA11 -> D4.A
  ; /LED_DRV_590 PC6  -> D5.A
  ; /LED_DRV_660 PC7  -> D6.A
  ; /PUMP_PWM    PB3  -> M1.pwm
  ; /PUMP_EN     PB4  -> M1.en
  ; /ONEWIRE     PB8  -> U9.2
  ; /SD_D0..D3   PC8-11 -> microSD
  ; /SD_CMD       PD2  -> microSD
  ; /SD_CLK       PC12 -> microSD
  ; /QSPI_*       PB2,10,11,12,13,14 -> U5

  (net 1 "SPI1_SCK")
  (net 2 "SPI1_MISO")
  (net 3 "SPI1_MOSI")
  (net 4 "ADC_CS")
  (net 5 "ADC_DRDY")
  (net 6 "SPI2_SCK")
  (net 7 "SPI2_MISO")
  (net 8 "SPI2_MOSI")
  (net 9 "LORA_CS")
  (net 10 "I2C1_SCL")
  (net 11 "I2C1_SDA")
  (net 12 "UART1_TX")
  (net 13 "UART1_RX")
  (net 14 "LED_DRV_255")
  (net 15 "LED_DRV_280")
  (net 16 "LED_DRV_365")
  (net 17 "LED_DRV_470")
  (net 18 "LED_DRV_590")
  (net 19 "LED_DRV_660")
  (net 20 "PUMP_PWM")
  (net 21 "PUMP_EN")
  (net 22 "ONEWIRE")
  (net 23 "SD_D0")
  (net 24 "SD_D1")
  (net 25 "SD_D2")
  (net 26 "SD_D3")
  (net 27 "SD_CMD")
  (net 28 "SD_CLK")
  (net 29 "+3V3")
  (net 30 "GND")
  (net 31 "VBAT")
  (net 32 "ANALOG_FLUOR_360")
  (net 33 "ANALOG_FLUOR_430")
  (net 34 "ANALOG_FLUOR_650")
  (net 35 "ANALOG_FLUOR_685")
  (net 36 "ANALOG_REF_255")
