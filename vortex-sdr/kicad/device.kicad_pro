(kicad_pro (version 20231022)
  (general
    (project "vortex-sdr")
  )
  (net_classes
    (net_class "Default" ""
      (clearance 0.10)
      (trace_width 0.15)
      (via_dia 0.40)
      (via_drill 0.20)
    )
    (net_class "Power" "VDD_3V3 VDD_1V8 VDD_3V3A VDD_RF VSRC GND"
      (clearance 0.15)
      (trace_width 0.30)
      (via_dia 0.60)
      (via_drill 0.30)
    )
    (net_class "RF_50" "NET_RF_IN NET_LNA_OUT NET_MIXER_RF NET_MIXER_IF NET_SAW_OUT NET_ADC_IN NET_LO_OUT"
      (clearance 0.25)
      (trace_width 0.35)
      (via_dia 0.40)
      (via_drill 0.20)
    )
    (net_class "LVDS_100" "NET_ADC_D0_P NET_ADC_D0_N NET_ADC_D1_P NET_ADC_D1_N NET_ADC_D2_P NET_ADC_D2_N NET_ADC_CLK_P NET_ADC_CLK_N"
      (clearance 0.10)
      (trace_width 0.10)
      (via_dia 0.40)
      (via_drill 0.20)
      (diff_pair_gap 0.15)
      (diff_pair_width 0.10)
    )
    (net_class "USB_90" "NET_USB_DP NET_USB_DM"
      (clearance 0.10)
      (trace_width 0.20)
      (via_dia 0.40)
      (via_drill 0.20)
      (diff_pair_gap 0.15)
      (diff_pair_width 0.20)
    )
    (net_class "HighSpeed" "NET_SPI1_SCK NET_SPI1_MOSI NET_SPI1_MISO NET_SPI2_SCK NET_SPI2_MOSI NET_SPI3_SCK NET_SPI3_MOSI NET_SPI3_MISO"
      (clearance 0.10)
      (trace_width 0.15)
      (via_dia 0.40)
      (via_drill 0.20)
    )
  )
  (design_rules
    (min_clearance 0.10)
    (min_track_width 0.10)
    (min_via_diameter 0.40)
    (min_via_drill 0.20)
    (min_microvia_diameter 0.25)
    (min_microvia_drill 0.10)
    (min_hole_to_hole 0.50)
    (min_silk_text_thickness 0.12)
  )
  (pcb_params
    (layer_count 4)
    (copper_thickness_outer 0.035)
    (copper_thickness_inner 0.0175)
    (board_thickness 1.6)
    (solder_mask "green")
    (silkscreen "white")
    (surface_finish "ENIG")
  )
)