  ;; ============================================================
  ;; Net labels / wires (representative subset)
  ;; ============================================================
  (wire (pts (xy 60 90)  (xy 55 90))    (net 2))   ; +3V3
  (wire (pts (xy 60 100) (xy 55 100))   (net 3))   ; GND
  (wire (pts (xy 180 120)(xy 190 120))  (net 8))   ; GPIO0/PEAK → LTC5500 IRQ
  (wire (pts (xy 180 115)(xy 190 115))  (net 9))   ; GPIO1/VLOW ← SE1010
  (wire (pts (xy 180 110)(xy 185 110))  (net 10))  ; GPIO4/SCK2 → ADC + FRAM
  (wire (pts (xy 80 180) (xy 95 180))   (net 10))  ; ADC SCLK
  (wire (pts (xy 80 175) (xy 95 175))   (net 11))  ; ADC DOUT → GPIO5/MISO
  (wire (pts (xy 180 105)(xy 190 105))  (net 11))  ; GPIO5/MISO
  (wire (pts (xy 180 100)(xy 190 100))  (net 12))  ; GPIO7/CS_FRAM
  (wire (pts (xy 180 95) (xy 190 95))   (net 13))  ; GPIO8/SCL → sensors
  (wire (pts (xy 180 90) (xy 190 90))   (net 14))  ; GPIO9/SDA → sensors
  (wire (pts (xy 180 85) (xy 190 85))   (net 15))  ; GPIO10/CS_ADC
  (wire (pts (xy 180 80) (xy 190 80))   (net 16))  ; GPIO11/DRDY ← ADC
  (wire (pts (xy 260 95) (xy 265 95))   (net 17))  ; LoRa SCK → GPIO18
  (wire (pts (xy 260 90) (xy 265 90))   (net 18))  ; LoRa MISO → GPIO19
  (wire (pts (xy 260 85) (xy 265 85))   (net 19))  ; LoRa MOSI → GPIO20
  (wire (pts (xy 260 80) (xy 265 80))   (net 20))  ; LoRa NSS → GPIO21
  (wire (pts (xy 260 75) (xy 265 75))   (net 21))  ; LoRa BUSY → GPIO17
  (wire (pts (xy 260 70) (xy 265 70))   (net 22))  ; LoRa DIO1 → GPIO16
  (wire (pts (xy 260 65) (xy 265 65))   (net 23))  ; LoRa NRST → GPIO15
  (wire (pts (xy 180 170)(xy 190 170))  (net 24))  ; SE1010 VOK → GPIO3
  (wire (pts (xy 180 180)(xy 190 180))  (net 4))   ; VSTORE → supercap+
  (wire (pts (xy 270 260)(xy 270 290))  (net 4))   ; supercap series stack
  (wire (pts (xy 340 180)(xy 350 180))  (net 8))   ; LTC5500 VOUT → peak IRQ

  (global_label "+3V3" (shape input)   (at 55 90)  (effects (font (size 1.2 1.2))))
  (global_label "GND"  (shape input)   (at 55 100) (effects (font (size 1.2 1.2))))
  (global_label "VBAT_SCAP" (shape input)(at 190 180)(effects (font (size 1.2 1.2))))
  (global_label "V_HARV" (shape input) (at 220 170)(effects (font (size 1.2 1.2))))

  (text "RainForge — Piezoelectric Raindrop Energy Harvester & Disdrometer\nAuthor: jayis1 — Copyright (C) 2026 jayis1\nLicense: CERN-OHL-S v2"
        (at 120 20) (effects (font (size 2 2) italic)))

  (instances (project "rainforge" (path "/rainforge-sch-0001")))
)