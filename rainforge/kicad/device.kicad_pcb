    (property "Author" "jayis1")
    (pad "1" thru_hole circle (size 1.5 1.5) (drill 0.8) (at 0 0) (layers "*.Cu" "*.Mask") (net 34))
    (pad "2" thru_hole circle (size 1.5 1.5) (drill 0.8) (at 0 2.54) (layers "*.Cu" "*.Mask") (net 35))
  )

  ;; ANT1 — 868 MHz PCB trace antenna (meandered inverted-F) at (70, 70)
  (footprint "RF_Antenna:PCB_Trace_MIFA_868MHz"
    (layer "F.Cu")
    (tstamp ant1)
    (at 70 70)
    (attr smd)
    (property "Reference" "ANT1" (at 0 -3))
    (property "Value"  "868MHz_MIFA" (at 0 3))
    (property "Author" "jayis1")
    (pad "1" smd rect (size 1.5 0.8) (at 0 0) (layers "F.Cu" "F.Mask") (net 36))  ; RF feed
  )

  ;; =========================================================
  ;; Representative copper traces
  ;; =========================================================
  (segment (start 40 35) (end 65 35) (width 0.15) (layer "F.Cu") (net 20))   ; LORA_SCK
  (segment (start 40 35) (end 20 20) (width 0.15) (layer "F.Cu") (net 10))   ; SPI2_SCK → ADC
  (segment (start 40 35) (end 35 65) (width 0.15) (layer "F.Cu") (net 10))   ; SPI2_SCK → FRAM
  (segment (start 40 35) (end 60 65) (width 0.15) (layer "F.Cu") (net 14))   ; I2C_SCL → SHT45
  (segment (start 40 35) (end 65 70) (width 0.15) (layer "F.Cu") (net 14))   ; I2C_SCL → BMP390
  (segment (start 20 50) (end 10 60) (width 0.15) (layer "F.Cu") (net 4))    ; VSTORE → supercap
  (segment (start 50 20) (end 20 50) (width 0.15) (layer "F.Cu") (net 5))    ; LTC3588 VOUT → SE1010 VIN
  (segment (start 55 55) (end 40 35) (width 0.15) (layer "F.Cu") (net 8))    ; PEAK_IRQ → MCU GPIO0
  (segment (start 5 15)  (end 50 20) (width 0.15) (layer "F.Cu") (net 28))   ; P1+ → LTC3588 PZ1 → ADC AIN0P
  (segment (start 5 15)  (end 20 20) (width 0.15) (layer "F.Cu") (net 28))   ; P1+ → ADC AIN0P

  ;; Vias to ground plane (In1.Cu)
  (via (at 40 35) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 65 35) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 20 20) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 20 50) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 35 65) (size 0.3) (drill 0.15) (layers "F.Cu" "B.Cu") (net 3))

  ;; Ground pour (In1.Cu is solid GND plane)
  (zone (layer "In1.Cu") (net 3)
    (connect_pads (clearance 0.2))
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 0 0) (xy 80 0) (xy 80 80) (xy 0 80)))
  )

  (instances (project "rainforge" (path "/rainforge-pcb-0001")))
)