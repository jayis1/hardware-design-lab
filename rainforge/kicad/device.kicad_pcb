(kicad_pcb
  (version 20240108)
  (generator "kicad")
  (generator_version "8.0")
  (general (thickness 1.6) (legacy_teardrops no))
  (paper "A4")
  (title_block
    (title "RainForge — Piezoelectric Raindrop Energy Harvester PCB")
    (date "2026-07-03")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "Copyright (C) 2026 jayis1")
    (comment 3 "License: CERN-OHL-S v2")
    (comment 4 "4-layer, 80x80mm, ENIG, circular")
  )

  (layers
    (0 "F.Cu" signal "top")
    (1 "In1.Cu" signal "gnd")
    (2 "In2.Cu" signal "pwr")
    (31 "B.Cu" signal "bottom")
    (32 "B.Adhes" user "B.Adhes")
    (33 "F.Adhes" user "F.Adhes")
    (34 "B.Paste" user "B.Paste")
    (35 "F.Paste" user "F.Paste")
    (36 "B.SilkS" user "B.SilkS")
    (37 "F.SilkS" user "F.SilkS")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "Dwgs.User")
    (44 "Edge.Cuts" user "Edge.Cuts")
    (45 "Margin" user "Margin")
  )

  (setup
    (pad_to_mask_clearance 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (excludeedgelayer true)
      (linewidth 0.100000)
      (plotframeref false)
      (usegerberattributes true)
      (usegerberextensions true)
      (via_min_size 0.3)
      (via_min_drill 0.15)
    )
  )

  ;; Board outline: 80 x 80 mm (square board; circular enclosure is
  ;; mechanical, the PCB is square to simplify panelization)
  (gr_line (start 0 0) (end 80 0) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 80 0) (end 80 80) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 80 80) (end 0 80) (layer "Edge.Cuts") (width 0.15))
  (gr_line (start 0 80) (end 0 0) (layer "Edge.Cuts") (width 0.15))

  ;; Mounting holes at corners (M3)
  (gr_circle (center 3 3) (end 5 3) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 77 3) (end 79 3) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 3 77) (end 5 77) (layer "Edge.Cuts") (width 0.15))
  (gr_circle (center 77 77) (end 79 77) (layer "Edge.Cuts") (width 0.15))

  (gr_text "RainForge v1.0  —  jayis1  —  CERN-OHL-S v2"
           (at 40 75) (layer "F.SilkS") (effects (font (size 1.0 1.0))))

