      "min_track_width": "0.15mm",
      "min_via_annular_ring": "0.1mm",
      "solder_mask_clearance": "0.05mm",
      "solder_paste_ratio": "-0.000mm",
      "solder_paste_ratio_absolute": "0.000mm"
    },
    "layers": {
      "copper": ["F.Cu", "In1.Cu", "In2.Cu", "B.Cu"],
      "signal": 4,
      "setup": {
        "F.Cu": {"type": "signal", "thickness": "0.035mm"},
        "In1.Cu": {"type": "signal", "thickness": "0.035mm"},
        "In2.Cu": {"type": "signal", "thickness": "0.035mm"},
        "B.Cu": {"type": "signal", "thickness": "0.035mm"}
      },
      "stackup": {
        "total_thickness": "1.6mm",
        "prepreg": [
          {"material": "FR4", "thickness": "0.2mm", "dielectric": "4.5"},
          {"material": "FR4", "thickness": "0.2mm", "dielectric": "4.5"},
          {"material": "FR4", "thickness": "0.2mm", "dielectric": "4.5"}
        ],
        "core": [
          {"material": "FR4", "thickness": "0.5mm", "dielectric": "4.5"},
          {"material": "FR4", "thickness": "0.5mm", "dielectric": "4.5"}
        ]
