  "design_settings": {
    "defaults": {
      "net_class": "Default",
      "track_width": "0.25mm",
      "via_size": "0.6mm",
      "via_drill": "0.3mm",
      "micro_via_size": "0.3mm",
      "micro_via_drill": "0.15mm"
