(kicad_pcb
  (version 20231127)
  (generator "jayis1")
  (general
    (thickness 1.6)
    (no_connect 0)
    (net_classes
      (net_class "Default" (clearance 0.15) (trace_width 0.25) (via_dia 0.6) (via_drill 0.3))
      (net_class "POWER" (clearance 0.2) (trace_width 0.5) (via_dia 0.7) (via_drill 0.35))
      (net_class "HV" (clearance 0.5) (trace_width 0.75) (via_dia 1.0) (via_drill 0.5))
      (net_class "DIFFERENTIAL" (clearance 0.2) (trace_width 0.15)
        (via_dia 0.5) (via_drill 0.25))
      (net_class "ANALOG" (clearance 0.3) (trace_width 0.2) (via_dia 0.5) (via_drill 0.25))
    )
  )

  (setup
    (last_trace_width 0.25)
    (user_trace_width (0.15) (0.2) (0.25) (0.5) (0.75) (1.0))
    (user_via (0.5 0.25) (0.6 0.3) (0.7 0.35) (1.0 0.5) (1.2 0.6))
    (board_outline_line_width 0.1)
    (copper_edge_clearance 0.3)
    (allow_soldermasks_bridges 0)
  )

  (board
    (title_block
      (title "SonicSight PCB Rev A")
      (date "2026-06-17")
      (company "jayis1")
      (comment 1 "Author: jayis1")
      (comment 2 "Copyright © 2026 jayis1. All rights reserved.")
      (comment 3 "160 × 120 mm, 4-layer, FR4, 1.6 mm, HASL")
    )
  )

  ; ========================================================================== ;
  ;  Board Outline — 160 mm × 120 mm
