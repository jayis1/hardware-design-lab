  (net 12 "SPI1_MISO")
  (net 13 "SPI1_SCK")
  (net 14 "SPI1_NSS")
  (net 15 "SX1262_RST")
  (net 16 "SX1262_BUSY")
  (net 17 "SX1262_DIO1")
  (net 18 "LORA_ANT")
  (net 19 "USART3_TX")
  (net 20 "USART3_RX")
  (net 21 "UART4_TX")
  (net 22 "UART4_RX")
  (net 23 "WIND_DE")
  (net 24 "USART6_TX")
  (net 25 "USART6_RX")
  (net 26 "ESP_RST")
