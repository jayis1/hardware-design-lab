  ; ---- Board outline (80 x 55 mm) ----
  (gr_line (start 0 0) (end 80 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 80 0) (end 80 55) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 80 55) (end 0 55) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 55) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  ; ---- Tracks (subset representative of the real routing) ----
  (segment (start 40 35) (end 20 55) (width 0.2) (layer "F.Cu") (net 11))
  (segment (start 20 55) (end 20 60) (width 0.2) (layer "F.Cu") (net 11))
  (segment (start 40 35) (end 60 55) (width 0.2) (layer "F.Cu") (net 7))
  (segment (start 15 25) (end 25 25) (width 0.2) (layer "F.Cu") (net 5))
  (segment (start 15 25) (end 15 30) (width 0.2) (layer "F.Cu") (net 2))
  (via (at 15 30) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 2))
  (segment (start 50 30) (end 50 35) (width 0.2) (layer "F.Cu") (net 2))
  (segment (start 52 30) (end 52 35) (width 0.2) (layer "F.Cu") (net 1))
  (via (at 52 35) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))

  ; ---- Ground pour on B.Cu ----
  (zone (layer "B.Cu") (net 1) (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 0 0) (xy 80 0) (xy 80 55) (xy 0 55)))
  )
  ; ---- 3V3 pour on In1.Cu ----
  (zone (layer "In1.Cu") (net 2) (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy 2 2) (xy 78 2) (xy 78 53) (xy 2 53)))
  )

  (dimension (type orthogonal) (layer "Dwgs.User")
    (pts (xy 0 0) (xy 80 0)) (height -3)
    (format (units mm) (units_format 0) (precision 1))
    (style (thickness 0.1) (arrow_length 1.5)))
  (dimension (type orthogonal) (layer "Dwgs.User")
    (pts (xy 0 0) (xy 0 55)) (height 84)
    (format (units mm) (units_format 0) (precision 1))
    (style (thickness 0.1) (arrow_length 1.5)))

  (gr_text "Pollen Scout - jayis1 - (c) 2026 - GPL-3.0"
    (at 40 52) (size 1.2) (thickness 0.15) (layer "F.SilkS"))
)