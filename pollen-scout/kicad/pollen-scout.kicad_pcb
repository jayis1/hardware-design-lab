(kicad_pcb
  (version 20231120)
  (generator "jayis1 - Pollen Scout PCB")
  (generator_version "7.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal "copper")
    (1 "In1.Cu" signal "copper")
    (2 "In2.Cu" signal "copper")
    (31 "B.Cu" signal "copper")
    (32 "B.Adhes" user "adhesive")
    (33 "F.Adhes" user "adhesive")
    (34 "B.Paste" user "solder_paste")
    (35 "F.Paste" user "solder_paste")
    (36 "B.SilkS" user "silk_screen")
    (37 "F.SilkS" user "silk_screen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "user")
    (41 "Cmts.User" user "user")
    (42 "Eco1.User" user "user")
    (43 "Eco2.User" user "user")
    (44 "Edge.Cuts" user "outline")
    (45 "Margin" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.1)
    (grid_origin 0 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output yes)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "+3V3")
  (net 3 "VBAT")
  (net 4 "VSOLAR")
  (net 5 "I2C1_SCL")
  (net 6 "I2C1_SDA")
