      (dxfusepcbtruefont yes)
      (psnegative no)
      (psa4output yes)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
