  (footprint "Connector_JST:JST-PH-2"
    (layer "F.Cu")
    (uuid "fp-bat1")
    (at -12 0 0)
    (property "Reference" "J2" (at -3 -2 0))
    (property "Value" "BAT" (at 0 3 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -1 0 0) (size 1 1.2) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 4 "VBAT"))
    (pad "2" smd rect (at 1 0 0) (size 1 1.2) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND")))

  ;; Y1: 32 MHz crystal
  (footprint "Crystal:Crystal_SMD_3.2x2.5mm"
    (layer "F.Cu")
    (uuid "fp-xtal1")
    (at -4 -3 0)
    (property "Reference" "Y1" (at -2 -2 0))
    (property "Value" "32MHz" (at 0 3 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -1.6 -1.25 0) (size 1.2 1.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 90 "XTAL_HF_P"))
    (pad "2" smd rect (at 1.6 -1.25 0) (size 1.2 1.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 91 "XTAL_HF_N")))

  ;; Y2: 32.768 kHz crystal
  (footprint "Crystal:Crystal_SMD_3215-2Pin"
    (layer "F.Cu")
    (uuid "fp-xtal2")
    (at 4 -3 0)
    (property "Reference" "Y2" (at -2 -2 0))
    (property "Value" "32.768kHz" (at 0 3 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -1.6 0 0) (size 1.2 1.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 92 "XTAL_LF_P"))
    (pad "2" smd rect (at 1.6 0 0) (size 1.2 1.4) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 93 "XTAL_LF_N")))

  ;; SW1: Button
  (footprint "Button_Switch_SMD:SW_SPST_B3U-1000P"
    (layer "F.Cu")
    (uuid "fp-btn1")
    (at 0 14 0)
    (property "Reference" "SW1" (at -2 -2 0))
    (property "Value" "BTN" (at 0 3 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -1.85 0 0) (size 1.1 1.2) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 60 "BUTTON"))
    (pad "2" smd rect (at 1.85 0 0) (size 1.1 1.2) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND")))

  ;; ---- Decoupling capacitors ----
  (footprint "Capacitor_SMD:C_0402"
    (layer "F.Cu") (uuid "fp-c1") (at -3 -1 0)
    (property "Reference" "C1" (at 0 -1 0))
    (property "Value" "100nF" (at 0 1 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -0.5 0 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD"))
    (pad "2" smd rect (at 0.5 0 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND")))

  (footprint "Capacitor_SMD:C_0402"
    (layer "F.Cu") (uuid "fp-c2") (at 3 -1 0)
    (property "Reference" "C2" (at 0 -1 0))
    (property "Value" "4.7µF" (at 0 1 0))
    (property "Author" "jayis1" (at 0 0 0))
    (pad "1" smd rect (at -0.5 0 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "VDD"))
    (pad "2" smd rect (at 0.5 0 0) (size 0.5 0.5) (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "GND")))

  ;; ---- Vias for GND and VDD planes ----
  (via (at -5 -5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))
  (via (at 5 -5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))
  (via (at -5 5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))
  (via (at 5 5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))
  (via (at 0 -5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))
  (via (at 0 5) (size 0.4) (drill 0.2) (layers "F.Cu" "B.Cu") (net 2 "GND"))

  ;; ---- Zones: GND pour on top and bottom ----
  (zone (net 2) (net_name "GND") (layer "F.Cu") (uuid "zone-gnd-f")
    (hatch edge 0.5)
    (connect_pads (spacing 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy -17.5 0) (xy 0 17.5) (xy 17.5 0) (xy 0 -17.5))))

  (zone (net 2) (net_name "GND") (layer "B.Cu") (uuid "zone-gnd-b")
    (hatch edge 0.5)
    (connect_pads (spacing 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy -17.5 0) (xy 0 17.5) (xy 17.5 0) (xy 0 -17.5))))

  (zone (net 1) (net_name "VDD") (layer "In2.Cu") (uuid "zone-vdd")
    (hatch edge 0.5)
    (connect_pads (spacing 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy -17.5 0) (xy 0 17.5) (xy 17.5 0) (xy 0 -17.5))))

  (zone (net 2) (net_name "GND") (layer "In1.Cu") (uuid "zone-gnd-in1")
    (hatch edge 0.5)
    (connect_pads (spacing 0.3))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon
      (pts (xy -17.5 0) (xy 0 17.5) (xy 17.5 0) (xy 0 -17.5))))

  ;; ---- Silk screen text ----
  (gr_text "TremorSense v1.0" (at 0 -14 0)
    (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (gr_text "jayis1 © 2026" (at 0 13 0)
    (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12))))

