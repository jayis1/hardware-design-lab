  ;; ---- Connections (wire netlist) ----
  ;; IMU SPI bus: SCLK→P0.04, MOSI→P0.05, MISO→P0.06, CS→P0.07, IRQ→P0.11
  ;; Display SPI: SCLK→P0.10, MOSI→P0.12, CS→P0.08, DC→P0.09, RST→P0.13, BL→P0.14
  ;; Flash SPI: SCLK→P0.17, MOSI→P0.18, MISO→P0.19, CS→P0.15, WP→P0.21, HOLD→P0.20
  ;; I²C bus: SCL→P0.26, SDA→P0.27 (MAX17048, SHT40, LPS22HB)
  ;; USB-C: DP→P0.24, DM→P0.25
  ;; Button: P0.23
  ;; NFC: P0.28, P0.29
  ;; Charge status: P0.31

  (nets
    (net "VDD" (code 1))
    (net "GND" (code 2))
    (net "VBUS" (code 3))
    (net "VBAT" (code 4))
    (net "VBAT_DIV" (code 5))
    (net "SPI2_SCLK" (code 10))
    (net "SPI2_MOSI" (code 11))
    (net "SPI2_MISO" (code 12))
    (net "IMU_CS" (code 13))
    (net "IMU_IRQ" (code 14))
    (net "SPI0_SCLK" (code 20))
    (net "SPI0_MOSI" (code 21))
    (net "DISP_CS" (code 22))
    (net "DISP_DC" (code 23))
    (net "DISP_RST" (code 24))
    (net "DISP_BL" (code 25))
    (net "SPI1_SCLK" (code 30))
    (net "SPI1_MOSI" (code 31))
    (net "SPI1_MISO" (code 32))
    (net "FLASH_CS" (code 33))
    (net "FLASH_WP" (code 34))
    (net "FLASH_HOLD" (code 35))
    (net "I2C_SCL" (code 40))
    (net "I2C_SDA" (code 41))
    (net "USB_DP" (code 50))
    (net "USB_DM" (code 51))
    (net "BUTTON" (code 60))
    (net "NFC_ANT1" (code 70))
    (net "NFC_ANT2" (code 71))
    (net "CHARGE_STAT" (code 80))
    (net "XTAL_HF_P" (code 90))
