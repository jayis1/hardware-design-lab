(kicad_pcb
  (version 20240108)
  (generator "kicad-pcb-editor")
  (generator_version "8.0")
  (general
    (thickness 0.4)
    (legacy_teardrops no)
  )
  (uuid "22222222-3333-4444-5555-666666666666")
  (paper "A4")
  (title_block
    (title "TactiScript — Wearable Fingertip Haptic Display Ring")
    (date "2026-07-06")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "Copyright (C) 2026 jayis1")
    (comment 3 "License: CERN-OHL-S v2")
    (comment 4 "6-layer rigid-flex, 22mm ring form factor")
  )

  ;; ================================================================
  ;; Layers (6-layer rigid-flex stackup)
  ;; ================================================================
  (layers
    (0 "F.Cu" signal "Top — components + actuator array inner face")
    (1 "In1.Cu" signal "Inner 1 — signal routing")
    (2 "In2.Cu" signal "Inner 2 — GND plane")
    (3 "In3.Cu" signal "Inner 3 — HV routing (120V)")
    (4 "In4.Cu" signal "Inner 4 — power plane (VBAT/VCC)")
    (5 "B.Cu" signal "Bottom — Qi coil + OLED + touch")
    (6 "F.Paste" user)
    (7 "B.Paste" user)
    (8 "F.SilkS" user "Silkscreen Top")
    (9 "B.SilkS" user "Silkscreen Bottom")
    (10 "F.Mask" user)
    (11 "B.Mask" user)
    (12 "Dwgs.User" user "User Drawings")
    (13 "Cmts.User" user "User Comments")
    (14 "F.Fab" user)
    (15 "B.Fab" user)
    (16 "F.CrtYd" user "Courtyard Top")
    (17 "B.CrtYd" user "Courtyard Bottom")
  )

  ;; ================================================================
  ;; Board setup
  ;; ================================================================
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.018))
      (layer "dielectric 1" (type "core") (thickness 0.05) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.018))
      (layer "dielectric 2" (type "core") (thickness 0.05) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.018))
      (layer "dielectric 3" (type "core") (thickness 0.05) (material "Polyimide flex"))
      (layer "In3.Cu" (type "copper") (thickness 0.018))
      (layer "dielectric 4" (type "core") (thickness 0.05) (material "FR4"))
      (layer "In4.Cu" (type "copper") (thickness 0.018))
      (layer "dielectric 5" (type "core") (thickness 0.05) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.018))
      (copper_finish "ENIG")
      (dielectric_constraints yes)
    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.04)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (subtract_mask_from_silk no)
      (outputformat 1)
      (mirror no)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "plots/")
    )
  )

