(kicad_project
  (version 1)
  (host "Chronos Pulser")
  (general
    (thickness 1.6)
    (legacy_netclass false)
  )
  (net_classes
    (class "Default"
      (clearance 0.2)
      (track_width 0.2)
      (via_dia 0.6)
      (via_drill 0.3)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
      (diff_pair_gap 0.2)
      (diff_pair_width 0.18)
    )
    (class "Power"
      (clearance 0.3)
      (track_width 0.5)
      (via_dia 0.8)
      (via_drill 0.4)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
    )
    (class "RF_50Ohm"
      (clearance 0.5)
      (track_width 0.30)
      (via_dia 0.6)
      (via_drill 0.3)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
    )
    (class "Diff_100Ohm"
      (clearance 0.3)
      (track_width 0.18)
      (via_dia 0.6)
      (via_drill 0.3)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
      (diff_pair_gap 0.20)
      (diff_pair_width 0.18)
    )
    (class "Diff_90Ohm"
      (clearance 0.3)
      (track_width 0.22)
      (via_dia 0.6)
      (via_drill 0.3)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
      (diff_pair_gap 0.18)
      (diff_pair_width 0.22)
    )
    (class "DDR3"
      (clearance 0.25)
      (track_width 0.30)
      (via_dia 0.6)
      (via_drill 0.3)
      (uvia_dia 0.3)
      (uvia_drill 0.1)
    )
  )
  (design_rules
    (rule "Min_track_width"
      (constraint min_track_width 0.10)
    )
    (rule "Min_clearance"
      (constraint min_clearance 0.13)
    )
    (rule "Min_via_drill"
      (constraint min_via_drill 0.20)
    )
    (rule "Min_annular_width"
      (constraint min_annular_width 0.125)
    )
    (rule "Board_edge_clearance"
      (constraint edge_clearance 0.50)
    )
    (rule "Solder_mask_expansion"
      (constraint solder_mask_expansion 0.05)
    )
    (rule "Solder_mask_min_width"
      (constraint solder_mask_min_width 0.10)
    )
  )
  (pcb_thickness 1.6)
  (board_outline
    (rect 100.0 70.0)
  )
  (stackup
    (layer "F.Cu" (type "signal") (thickness 0.035) (material "copper"))
    (layer "In1.Cu" (type "plane") (thickness 0.035) (material "copper") (name "GND"))
    (layer "In2.Cu" (type "plane") (thickness 0.035) (material "copper") (name "PWR"))
    (layer "B.Cu" (type "signal") (thickness 0.035) (material "copper"))
    (dielectric 1 (type "prepreg") (thickness 0.12) (material "FR-4") (epsilon_r 4.2))
    (dielectric 2 (type "core") (thickness 0.71) (material "FR-4") (epsilon_r 4.5))
    (dielectric 3 (type "prepreg") (thickness 0.12) (material "FR-4") (epsilon_r 4.2))
  )
)
