  (wire (pts (xy 26.67 45.72) (xy 27.94 45.72)) (stroke (width 0.1524)) (net "XL2"))
  (wire (pts (xy 19.05 58.42) (xy 17.78 58.42)) (stroke (width 0.1524)) (net "OSC32_IN"))
  (wire (pts (xy 26.67 58.42) (xy 27.94 58.42)) (stroke (width 0.1524)) (net "OSC32_OUT"))

  ; --- Solar input ---
  (wire (pts (xy 34.29 127) (xy 36.83 127)) (stroke (width 0.1524)) (net "SOLAR+"))
  (wire (pts (xy 34.29 132.08) (xy 36.83 132.08)) (stroke (width 0.1524)) (net "SOLAR-"))
