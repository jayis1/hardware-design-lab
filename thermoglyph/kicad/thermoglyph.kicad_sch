  (global_label "VDD" (shape input) (at 50.8 78.74 180) (effects (font (size 1.27 1.27))))
  (global_label "GND" (shape input) (at 50.8 100.33 180) (effects (font (size 1.27 1.27))))

  ; --- BOM annotation ---
  (sheet (at 15.24 15.24) (size 175.26 165.1)
    (stroke (width 0.1524) (type solid))
    (fill (type none))
    (property "Sheetname" "ThermoGlyph Main")
    (property "Sheetfile" "thermoglyph.kicad_sch")
    (property "Author" "jayis1")
  )

  ; --- Design notes ---
  (text "ThermoGlyph v1.0 Schematic\nAuthor: jayis1\nCopyright (c) 2026 jayis1\n\nKey nets:\n- I2C0: TMP117[0-5], Si7051, LTR-390UV, MAX17048\n- I2C1: TMP117[6-11]\n- SPI0: SX1262 LoRa (8 MHz)\n- SPI1: ICM-42688 IMU (1 MHz)\n- TLC59711: 4x daisy-chain, 12-ch PWM each\n- Row select: 3-bit address + 2 direction pins\n- Safety: THERM_FAULT (active low) → P-FET cutoff\n\nThermal array: 12 cols × 8 rows = 96 micro-TEC cells\nTime-multiplexed row scan at 200 Hz\nPID loop: 200 Hz, per-row independent\n\nPower: 500mAh LiPo + 2× solar cells via BQ25570\nRuntime: 14h active, 5 days standby"
    (at 25.4 170.18 0)
    (effects (font (size 1.5 1.5)) (justify left))
  )

  (attr (draw) (exclude_from_sim no) (in_bom no) (on_board no))
