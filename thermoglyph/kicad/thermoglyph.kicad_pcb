(kicad_pcb
  (version 20240108)
  (generator "kicad_pcb_new")
  (generator_version "8.0")
  (general
    (thickness 0.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "ThermoGlyph — Wearable Thermal-Tactile Display PCB")
    (date "2026-07-15")
    (rev "1.0")
    (company "jayis1")
    (comment 1 "Author: jayis1")
    (comment 2 "Copyright (c) 2026 jayis1")
    (comment 3 "License: CERN-OHL-S v2")
    (comment 4 "60×45mm, 4-layer, nRF5340 + SX1262 + 96-cell TEC array")
  )

  ; ============================================================================
  ; LAYER STACKUP (4-layer)
  ; ============================================================================
  (layers
    (0 "F.Cu" signal "Top Copper — Components + RF + TEC pads")
    (1 "In1.Cu" signal "Inner 1 — GND plane (solid)")
    (2 "In2.Cu" signal "Inner 2 — Power plane (3.3V / TEC power)")
    (3 "B.Cu" signal "Bottom Copper — Components + thermal spreading")
    (4 "B.Adhes" user "Bottom Adhesive")
    (5 "F.Adhes" user "Top Adhesive")
    (6 "B.Paste" user "Bottom Solder Paste")
    (7 "F.Paste" user "Top Solder Paste")
    (8 "B.SilkS" user "Bottom Silkscreen")
    (9 "F.SilkS" user "Top Silkscreen")
    (10 "B.Mask" user "Bottom Solder Mask")
    (11 "F.Mask" user "Top Solder Mask")
    (12 "Dwgs.User" user "User Drawings")
    (13 "Cmts.User" user "User Comments")
    (14 "Eco1.User" user "Eco1")
    (15 "Eco2.User" user "Eco2")
    (16 "Edge.Cuts" user "Board Outline")
    (17 "Margin" user "Margin")
    (18 "B.CrtYd" user "Bottom Courtyard")
    (19 "F.CrtYd" user "Top Courtyard")
    (20 "B.Fab" user "Bottom Fabrication")
    (21 "F.Fab" user "Top Fabrication")
  )

  ; ============================================================================
  ; SETUP
  ; ============================================================================
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.018))
      (layer "F.Paste" (type "solderpaste"))
      (layer "F.Mask" (type "soldermask") (thickness 0.01))
      (layer "Dielectric 1" (type "dielectric") (thickness 0.18) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.018))
      (layer "Dielectric 2" (type "dielectric") (thickness 0.18) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.018))
      (layer "Dielectric 3" (type "dielectric") (thickness 0.18) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.018))
      (layer "B.Mask" (type "soldermask") (thickness 0.01))
      (layer "B.Paste" (type "solderpaste"))
      (copper_finish "ENIG")
      (dielectric_constraints no)
    )
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0.04)
    (grid_origin 0 0)
    (drawings 20)
    (tracks 200)
    (zones 4)
    (keepouts 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 6)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits no)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output yes)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/"))
  )

